@{
    ViewBag.Title = "Página não encontrada";
    Layout = "_Layout";
}

<div style="min-height:70vh; display:flex; align-items:center; justify-content:center; text-align:center; padding:2rem;">
    <div>
        <div class="font-playfair" style="font-size:8rem; font-weight:700; line-height:1; background:linear-gradient(135deg,#D4AF37,#A08020); -webkit-background-clip:text; -webkit-text-fill-color:transparent; margin-bottom:1rem;">
            404
        </div>
        <h1 class="font-playfair" style="font-size:2rem; font-weight:600; margin-bottom:1rem;">Página não encontrada</h1>
        <p style="color:rgba(255,255,255,0.4); margin-bottom:2.5rem; max-width:400px; line-height:1.7;">
            A página que você procura foi movida, removida ou simplesmente não existe.
        </p>
        <div style="display:flex; gap:1rem; justify-content:center;">
            <a href="/catalogo" class="btn-gold" style="padding:0.75rem 2rem; font-size:0.8rem; letter-spacing:0.1em; display:inline-block;">Ver Catálogo</a>
            <a href="/" class="btn-gold-outline" style="padding:0.75rem 2rem; font-size:0.8rem; letter-spacing:0.1em; display:inline-block;">Ir para Início</a>
        </div>
    </div>
</div>
