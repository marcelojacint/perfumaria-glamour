<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Title ?? "Glamour") - Perfumaria e Acessórios</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-black text-white font-inter antialiased">

    <!-- Barra de benefícios -->
    <div class="bg-gold text-black text-xs text-center py-2 px-4 tracking-widest uppercase font-semibold">
        Frete grátis acima de R$&nbsp;150 &nbsp;|&nbsp; Pague na entrega ou retirada &nbsp;|&nbsp; Atendimento personalizado
    </div>

    <!-- Header -->
    <header class="border-b border-gold/30 bg-black/95 sticky top-0 z-50 backdrop-blur">
        <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-20">
            <a href="/" class="flex items-center gap-3">
                <span class="font-playfair text-3xl font-bold text-gradient">Glamour</span>
                <span class="text-gold/60 text-xs tracking-[0.3em] uppercase hidden sm:block">Perfumaria</span>
            </a>

            <nav class="hidden md:flex items-center gap-8 text-sm tracking-wider">
                <a href="/catalogo" class="text-white/80 hover:text-gold transition-colors uppercase">Catálogo</a>
                <a href="/catalogo?genero=Feminino" class="text-white/80 hover:text-gold transition-colors uppercase">Feminino</a>
                <a href="/catalogo?genero=Masculino" class="text-white/80 hover:text-gold transition-colors uppercase">Masculino</a>
                <a href="/quiz" class="text-gold hover:text-gold transition-colors uppercase" style="font-size:0.7rem; border:1px solid rgba(212,175,55,0.4); padding:0.25rem 0.75rem; letter-spacing:0.12em;">Quiz ✦</a>
            </nav>

            <div class="flex items-center gap-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/favoritos" class="text-white/60 hover:text-gold transition-colors" title="Favoritos" style="font-size:1.125rem; line-height:1;">♡</a>
                    <a href="/conta/meus-pedidos" class="text-white/60 hover:text-gold transition-colors" title="Minha Conta">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                    </a>
                    <form method="post" action="/conta/logout" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-white/60 hover:text-gold transition-colors text-xs tracking-wider uppercase">Sair</button>
                    </form>
                }
                else
                {
                    <a href="/conta/login" class="text-white/60 hover:text-gold transition-colors text-xs tracking-wider uppercase">Entrar</a>
                }

                <a href="/carrinho" class="relative text-white/60 hover:text-gold transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
                    <span id="badge-carrinho" class="absolute -top-2 -right-2 bg-gold text-black text-xs w-4 h-4 rounded-full flex items-center justify-center font-bold hidden">0</span>
                </a>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="border-t border-gold/20 bg-zinc-950 mt-20">
        <div class="max-w-7xl mx-auto px-4 py-16 grid grid-cols-1 md:grid-cols-4 gap-10">
            <div>
                <span class="font-playfair text-2xl font-bold text-gradient block mb-4">Glamour</span>
                <p class="text-white/40 text-sm leading-relaxed">Perfumaria e acessórios com sofisticação e elegância para cada ocasião.</p>
            </div>
            <div>
                <h4 class="text-gold font-semibold text-sm tracking-wider uppercase mb-4">Categorias</h4>
                <ul class="space-y-2 text-sm text-white/50">
                    <li><a href="/catalogo?genero=Feminino" class="hover:text-gold transition-colors">Feminino</a></li>
                    <li><a href="/catalogo?genero=Masculino" class="hover:text-gold transition-colors">Masculino</a></li>
                    <li><a href="/catalogo?genero=Unissex" class="hover:text-gold transition-colors">Unissex</a></li>
                    <li><a href="/catalogo" class="hover:text-gold transition-colors">Acessórios</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-gold font-semibold text-sm tracking-wider uppercase mb-4">Atendimento</h4>
                <ul class="space-y-2 text-sm text-white/50">
                    <li>Seg-Sex: 9h às 18h</li>
                    <li>Sáb: 9h às 14h</li>
                    <li><a href="mailto:contato@glamour.com" class="hover:text-gold transition-colors">contato@glamour.com</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-gold font-semibold text-sm tracking-wider uppercase mb-4">Informações</h4>
                <ul class="space-y-2 text-sm text-white/50">
                    <li><a href="#" class="hover:text-gold transition-colors">Política de Privacidade</a></li>
                    <li><a href="#" class="hover:text-gold transition-colors">Trocas e Devoluções</a></li>
                    <li><a href="#" class="hover:text-gold transition-colors">Formas de Pagamento</a></li>
                </ul>
            </div>
        </div>
        <div class="border-t border-white/5 text-center text-white/20 text-xs py-6">
            &copy; @DateTime.Now.Year Glamour Perfumaria e Acessórios. Todos os direitos reservados.
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        fetch('/carrinho/quantidade').then(r => r.json()).then(q => {
            const badge = document.getElementById('badge-carrinho');
            if (q > 0) { badge.textContent = q; badge.classList.remove('hidden'); }
        }).catch(() => {});
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
