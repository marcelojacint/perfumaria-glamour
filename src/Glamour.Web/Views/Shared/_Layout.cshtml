@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    var lojaTelefone = Config["Loja:Telefone"] ?? "";
    var lojaWhatsapp = Config["Loja:WhatsApp"] ?? "";
    var lojaEmail = Config["Loja:Email"] ?? "";
    var lojaEndereco = Config["Loja:EnderecoLoja"] ?? "";
    var lojaHorario = Config["Loja:HorarioFuncionamento"] ?? "";
    var mapaUrl = "https://www.google.com/maps/search/?api=1&query=" + Uri.EscapeDataString(lojaEndereco);
    var whatsappUrl = "https://wa.me/" + lojaWhatsapp;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Title ?? "Glamour") - Perfumaria e Acessórios</title>
    <meta name="description" content="@(ViewBag.MetaDescription ?? "Glamour Perfumaria e Acessórios — perfumes exclusivos e acessórios sofisticados com entrega ou retirada na loja.")" />
    <meta name="keywords" content="@(ViewBag.MetaKeywords ?? "perfume, perfumaria, fragrância, glamour, acessórios")" />
    <meta property="og:title" content="@(ViewBag.Title ?? "Glamour") - Perfumaria e Acessórios" />
    <meta property="og:description" content="@(ViewBag.MetaDescription ?? "Perfumes exclusivos e acessórios sofisticados.")" />
    <meta property="og:type" content="@(ViewBag.OgType ?? "website")" />
    @if (ViewBag.OgImage != null) { <meta property="og:image" content="@ViewBag.OgImage" /> }
    <link rel="canonical" href="@(ViewBag.CanonicalUrl ?? $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#D4AF37" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-black text-white font-inter antialiased">

    <div class="bg-gold text-black text-xs text-center py-2 px-4 tracking-widest uppercase font-semibold">
        Frete grátis acima de R$&nbsp;150 &nbsp;|&nbsp; Pague na entrega ou retirada &nbsp;|&nbsp; Atendimento personalizado
    </div>

    <header class="border-b border-gold/30 bg-black/95 sticky top-0 z-50 backdrop-blur" x-data="{ menuAberto: false }">
        <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-20">
            <button type="button" class="md:hidden text-white/70 hover:text-gold transition-colors" @@click="menuAberto = !menuAberto" aria-label="Menu">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>

            <a href="/" class="flex items-center gap-3">
                <span class="font-playfair text-3xl font-bold text-gradient">Glamour</span>
                <span class="text-gold/60 text-xs tracking-[0.3em] uppercase hidden sm:block">Perfumaria</span>
            </a>

            <nav class="hidden md:flex items-center gap-8 text-sm tracking-wider">
                <a href="/catalogo" class="text-white/80 hover:text-gold transition-colors uppercase">Catálogo</a>
                <a href="/catalogo?genero=Feminino" class="text-white/80 hover:text-gold transition-colors uppercase">Feminino</a>
                <a href="/catalogo?genero=Masculino" class="text-white/80 hover:text-gold transition-colors uppercase">Masculino</a>
                <a href="/quiz" class="text-gold hover:text-gold transition-colors uppercase" style="font-size:0.7rem; border:1px solid rgba(212,175,55,0.4); padding:0.25rem 0.75rem; letter-spacing:0.12em;">Quiz ✦</a>
            </nav>

            <div x-data="{ aberto: false, q: '', resultados: [] }" style="position:relative; display:none;" class="md:block">
                <div style="display:flex; align-items:center; border:1px solid rgba(255,255,255,0.1); background:rgba(24,24,27,0.6); padding:0.35rem 0.75rem; gap:0.5rem;">
                    <svg style="width:14px; height:14px; color:rgba(255,255,255,0.4);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    <input type="text" x-model="q" placeholder="Buscar perfume..." style="background:transparent; border:none; color:#fff; font-size:0.8rem; outline:none; width:130px;"
                           @@focus="aberto=true" @@blur="setTimeout(()=>aberto=false,200)"
                           @@input.debounce.300ms="if(q.length>=2) fetch('/busca/sugestoes?q='+encodeURIComponent(q)).then(r=>r.json()).then(d=>resultados=d)" />
                </div>
                <div x-show="aberto && resultados.length" style="position:absolute; top:calc(100% + 4px); right:0; min-width:280px; background:#18181b; border:1px solid rgba(212,175,55,0.2); z-index:200;">
                    <template x-for="p in resultados" :key="p.id">
                        <a :href="'/produto/'+p.slug" style="display:flex; align-items:center; gap:0.6rem; padding:0.5rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">
                            <template x-if="p.imagem"><img :src="p.imagem" style="width:2.25rem; height:2.25rem; object-fit:cover; flex-shrink:0;" /></template>
                            <div><div style="font-size:0.8rem; color:#fff;" x-text="p.nome"></div><div style="font-size:0.7rem; color:#D4AF37;" x-text="'R$ '+p.preco.toFixed(2).replace('.',',')"></div></div>
                        </a>
                    </template>
                    <a :href="'/catalogo?busca='+q" style="display:block; padding:0.4rem 0.75rem; font-size:0.72rem; color:rgba(212,175,55,0.6); text-align:center;">Ver todos →</a>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <div class="hidden md:flex items-center gap-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/favoritos" class="text-white/60 hover:text-gold transition-colors" title="Favoritos" style="font-size:1.125rem; line-height:1;">♡</a>
                        <a href="/conta/meus-pedidos" class="text-white/60 hover:text-gold transition-colors" title="Minha Conta">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                        </a>
                        <form method="post" action="/conta/logout" class="inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-white/60 hover:text-gold transition-colors text-xs tracking-wider uppercase">Sair</button>
                        </form>
                    }
                    else
                    {
                        <a href="/conta/login" class="text-white/60 hover:text-gold transition-colors text-xs tracking-wider uppercase">Entrar</a>
                    }
                </div>

                <a href="/carrinho" class="relative text-white/60 hover:text-gold transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
                    <span id="badge-carrinho" class="absolute -top-2 -right-2 bg-gold text-black text-xs w-4 h-4 rounded-full flex items-center justify-center font-bold hidden">0</span>
                </a>
            </div>
        </div>

        <div class="md:hidden" x-show="menuAberto" x-transition @@click.outside="menuAberto = false"
             style="border-top:1px solid rgba(212,175,55,0.2); background:#0A0A0A;">
            <nav class="px-4 py-4 flex flex-col">
                <a href="/catalogo" class="py-3 text-white/80 text-sm tracking-wider uppercase border-b border-white/5">Catálogo</a>
                <a href="/catalogo?genero=Feminino" class="py-3 text-white/80 text-sm tracking-wider uppercase border-b border-white/5">Feminino</a>
                <a href="/catalogo?genero=Masculino" class="py-3 text-white/80 text-sm tracking-wider uppercase border-b border-white/5">Masculino</a>
                <a href="/catalogo?genero=Unissex" class="py-3 text-white/80 text-sm tracking-wider uppercase border-b border-white/5">Unissex</a>
                <a href="/quiz" class="py-3 text-gold text-sm tracking-wider uppercase border-b border-white/5">Quiz Olfativo ✦</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/favoritos" class="py-3 text-white/80 text-sm tracking-wider uppercase border-b border-white/5">Favoritos</a>
                    <a href="/conta/perfil" class="py-3 text-white/80 text-sm tracking-wider uppercase border-b border-white/5">Minha Conta</a>
                    <a href="/conta/meus-pedidos" class="py-3 text-white/80 text-sm tracking-wider uppercase border-b border-white/5">Meus Pedidos</a>
                    <form method="post" action="/conta/logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="py-3 text-white/80 text-sm tracking-wider uppercase w-full text-left">Sair</button>
                    </form>
                }
                else
                {
                    <a href="/conta/login" class="py-3 text-white/80 text-sm tracking-wider uppercase">Entrar / Criar Conta</a>
                }
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="border-t border-gold/20 bg-zinc-950 mt-20">
        <div class="max-w-7xl mx-auto px-4 py-16 grid grid-cols-1 md:grid-cols-4 gap-10">
            <div>
                <span class="font-playfair text-2xl font-bold text-gradient block mb-4">Glamour</span>
                <p class="text-white/40 text-sm leading-relaxed">Perfumaria e acessórios com sofisticação e elegância para cada ocasião.</p>
            </div>
            <div>
                <h4 class="text-gold font-semibold text-sm tracking-wider uppercase mb-4">Categorias</h4>
                <ul class="space-y-2 text-sm text-white/50">
                    <li><a href="/catalogo?genero=Feminino" class="hover:text-gold transition-colors">Feminino</a></li>
                    <li><a href="/catalogo?genero=Masculino" class="hover:text-gold transition-colors">Masculino</a></li>
                    <li><a href="/catalogo?genero=Unissex" class="hover:text-gold transition-colors">Unissex</a></li>
                    <li><a href="/catalogo" class="hover:text-gold transition-colors">Acessórios</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-gold font-semibold text-sm tracking-wider uppercase mb-4">Atendimento</h4>
                <ul class="space-y-2 text-sm text-white/50">
                    <li>
                        <a href="@mapaUrl" target="_blank" rel="noopener" class="hover:text-gold transition-colors flex items-start gap-2">
                            <span class="text-gold">📍</span> <span>@lojaEndereco</span>
                        </a>
                    </li>
                    <li>
                        <a href="@whatsappUrl" target="_blank" rel="noopener" class="hover:text-gold transition-colors flex items-center gap-2">
                            <span class="text-gold">📱</span> @lojaTelefone
                        </a>
                    </li>
                    <li>
                        <a href="mailto:@lojaEmail" class="hover:text-gold transition-colors flex items-center gap-2">
                            <span class="text-gold">✉️</span> @lojaEmail
                        </a>
                    </li>
                    <li class="text-white/30 text-xs pt-1">@lojaHorario</li>
                </ul>
            </div>
            <div>
                <h4 class="text-gold font-semibold text-sm tracking-wider uppercase mb-4">Informações</h4>
                <ul class="space-y-2 text-sm text-white/50">
                    <li><a href="/politica-de-privacidade" class="hover:text-gold transition-colors">Política de Privacidade</a></li>
                    <li><a href="/sobre" class="hover:text-gold transition-colors">Sobre Nós</a></li>
                    <li><a href="/contato" class="hover:text-gold transition-colors">Contato</a></li>
                </ul>
            </div>
        </div>
        <div class="border-t border-white/5 text-center text-white/20 text-xs py-6">
            &copy; @DateTime.Now.Year Glamour Perfumaria e Acessórios. Todos os direitos reservados.
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        fetch('/carrinho/quantidade').then(r => r.json()).then(q => {
            const badge = document.getElementById('badge-carrinho');
            if (q > 0) { badge.textContent = q; badge.classList.remove('hidden'); }
        }).catch(() => {});

        (function() {
            if (!localStorage.getItem('glamour_cookie_consent')) {
                const b = document.createElement('div');
                b.id = 'cookie-banner';
                b.innerHTML = `<div style="position:fixed;bottom:0;left:0;right:0;z-index:9999;background:rgba(9,9,11,0.97);border-top:1px solid rgba(212,175,55,0.2);padding:1rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                    <p style="color:rgba(255,255,255,0.6);font-size:0.8rem;margin:0;flex:1;">
                        Usamos cookies para melhorar sua experiência. Ao continuar, você concorda com nossa
                        <a href="#" style="color:#D4AF37;">Política de Privacidade</a>.
                    </p>
                    <div style="display:flex;gap:0.75rem;">
                        <button onclick="document.getElementById('cookie-banner').remove();localStorage.setItem('glamour_cookie_consent','accepted');"
                                style="background:linear-gradient(135deg,#D4AF37,#A08020);color:#000;border:none;padding:0.5rem 1.25rem;font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;">
                            Aceitar
                        </button>
                        <button onclick="document.getElementById('cookie-banner').remove();localStorage.setItem('glamour_cookie_consent','essential');"
                                style="background:none;border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.5);padding:0.5rem 1rem;font-size:0.75rem;cursor:pointer;">
                            Apenas Essenciais
                        </button>
                    </div>
                </div>`;
                document.body.appendChild(b);
            }
        })();

        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(() => {});
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
