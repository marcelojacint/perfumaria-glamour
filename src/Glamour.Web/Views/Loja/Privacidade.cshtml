@{
    ViewBag.Title = "Política de Privacidade";
}

<div class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="font-playfair" style="font-size:2.5rem; font-weight:700; margin-bottom:0.5rem;">Política de Privacidade</h1>
    <p style="color:rgba(255,255,255,0.3); font-size:0.8rem; margin-bottom:3rem;">Atualizada em @DateTime.Now.ToString("dd/MM/yyyy")</p>

    @{
        var secoes = new[] {
            ("1. Dados Coletados", "Coletamos apenas os dados necessários para processar seus pedidos: nome, e-mail, telefone e endereço de entrega. Não armazenamos dados de cartão de crédito — o pagamento é realizado presencialmente na entrega ou retirada."),
            ("2. Uso dos Dados", "Seus dados são utilizados exclusivamente para: processar pedidos, enviar confirmações por e-mail, entrar em contato sobre sua compra e enviar a newsletter (apenas se você se inscreveu voluntariamente)."),
            ("3. Compartilhamento", "Não vendemos, alugamos ou compartilhamos seus dados com terceiros, exceto transportadoras parceiras necessárias para a entrega do seu pedido."),
            ("4. Cookies", "Utilizamos cookies essenciais para o funcionamento da loja (carrinho, sessão) e cookies analíticos opcionais. Você pode recusar os cookies não essenciais pelo banner exibido no primeiro acesso."),
            ("5. Seus Direitos (LGPD)", "Conforme a Lei 13.709/2018 (LGPD), você tem direito a: acessar seus dados, corrigir informações incorretas, solicitar a exclusão da sua conta e cancelar o recebimento de newsletters. Entre em contato pelo e-mail informado na página de contato."),
            ("6. Segurança", "Utilizamos HTTPS, hashing de senhas (PBKDF2) e não armazenamos dados sensíveis de pagamento. Nosso banco de dados é protegido por autenticação e backups diários."),
        };
    }

    <div style="display:flex; flex-direction:column; gap:2rem;">
        @foreach (var (titulo, texto) in secoes)
        {
            <div>
                <h2 class="font-playfair" style="font-size:1.125rem; font-weight:600; color:#D4AF37; margin-bottom:0.5rem;">@titulo</h2>
                <p style="color:rgba(255,255,255,0.6); font-size:0.875rem; line-height:1.8;">@texto</p>
            </div>
        }
    </div>

    <div style="margin-top:3rem; border-top:1px solid rgba(255,255,255,0.08); padding-top:1.5rem;">
        <a href="/contato" style="color:#D4AF37; font-size:0.875rem;">Dúvidas? Entre em contato →</a>
    </div>
</div>
