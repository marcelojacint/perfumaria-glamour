@{
    ViewBag.Title = "Sobre Nós";
}

<div class="max-w-4xl mx-auto px-4 py-16">
    <div style="text-align:center; margin-bottom:4rem;">
        <p class="text-gold" style="font-size:0.65rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:0.75rem;">Nossa História</p>
        <h1 class="font-playfair" style="font-size:3rem; font-weight:700; margin-bottom:1.5rem;">
            Glamour <span class="text-gradient">Perfumaria</span>
        </h1>
        <p style="color:rgba(255,255,255,0.5); font-size:1rem; line-height:1.8; max-width:600px; margin:0 auto;">
            Nascemos da paixão pela arte das fragrâncias e pela elegância que um bom perfume pode trazer ao cotidiano.
            Nossa missão é oferecer perfumes exclusivos e acessórios sofisticados com o atendimento personalizado que você merece.
        </p>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:2rem; margin-bottom:4rem;">
        @foreach (var (num, titulo, desc) in new[] {
            ("500+", "Fragrâncias", "Curadoria exclusiva dos melhores perfumes nacionais e importados"),
            ("10.000+", "Clientes", "Clientes satisfeitos que confiam na nossa seleção e atendimento"),
            ("5 anos", "Experiência", "Anos dedicados a levar sofisticação e elegância para nossos clientes")
        })
        {
            <div style="text-align:center; border:1px solid rgba(212,175,55,0.2); padding:2rem;">
                <div class="font-playfair" style="font-size:2.5rem; font-weight:700; color:#D4AF37; margin-bottom:0.5rem;">@num</div>
                <div style="font-weight:600; margin-bottom:0.5rem;">@titulo</div>
                <div style="color:rgba(255,255,255,0.4); font-size:0.875rem; line-height:1.6;">@desc</div>
            </div>
        }
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:center; margin-bottom:4rem;">
        <div>
            <h2 class="font-playfair" style="font-size:1.75rem; font-weight:600; margin-bottom:1rem;">Nossos Valores</h2>
            <div style="display:flex; flex-direction:column; gap:1rem;">
                @foreach (var (icone, titulo, desc) in new[] {
                    ("✦", "Autenticidade", "Todos os nossos produtos são 100% originais, com procedência garantida."),
                    ("◇", "Elegância", "Acreditamos que o luxo está nos detalhes — do produto ao atendimento."),
                    ("◈", "Confiança", "Pagamento sempre na entrega. Sem riscos, sem surpresas.")
                })
                {
                    <div style="display:flex; gap:1rem;">
                        <span style="color:#D4AF37; font-size:1.25rem; flex-shrink:0; margin-top:0.2rem;">@icone</span>
                        <div>
                            <div style="font-weight:600; margin-bottom:0.2rem;">@titulo</div>
                            <div style="color:rgba(255,255,255,0.5); font-size:0.875rem; line-height:1.6;">@desc</div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div style="border:1px solid rgba(212,175,55,0.15); background:linear-gradient(135deg, rgba(212,175,55,0.05), rgba(9,9,11,0.8)); padding:2.5rem; text-align:center;">
            <div class="font-playfair text-gradient" style="font-size:3rem; font-weight:700; margin-bottom:1rem;">Glamour</div>
            <p style="color:rgba(255,255,255,0.4); font-size:0.875rem; line-height:1.8; font-style:italic;">
                "A essência da elegância está na simplicidade sofisticada — um perfume que conta sua história sem dizer uma palavra."
            </p>
        </div>
    </div>

    <div style="text-align:center;">
        <a href="/catalogo" class="btn-gold" style="padding:0.875rem 2.5rem; font-size:0.875rem; display:inline-block; margin-right:1rem;">Ver Catálogo</a>
        <a href="/contato" class="btn-gold-outline" style="padding:0.875rem 2rem; font-size:0.875rem; display:inline-block;">Fale Conosco</a>
    </div>
</div>
