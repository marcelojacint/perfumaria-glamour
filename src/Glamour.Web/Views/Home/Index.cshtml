@{
    ViewBag.Title = "Início";
    var promocoes = ViewBag.Promocoes as IEnumerable<Glamour.Application.DTOs.ProdutoListagemDto> ?? [];
    var destaques = ViewBag.Destaques as IEnumerable<Glamour.Application.DTOs.ProdutoListagemDto> ?? [];
    var categorias = ViewBag.Categorias as IEnumerable<Glamour.Application.DTOs.CategoriaDto> ?? [];
    var campanhas = ViewBag.Campanhas as IEnumerable<Glamour.Application.DTOs.CampanhaDto> ?? [];
    var hero = ViewBag.Hero as Glamour.Application.DTOs.HeroDto;
    var temImagemHero = hero != null && !string.IsNullOrEmpty(hero.ImagemFundoUrl);
    bool newsletterOk = TempData["NewsletterSucesso"] != null;
}

<section class="relative flex items-center justify-center overflow-hidden" style="min-height:@(temImagemHero ? "55vh" : "38vh");">
    @if (temImagemHero)
    {
        <div class="absolute inset-0" style="background-image:url('@hero!.ImagemFundoUrl'); background-size:cover; background-position:center;"></div>
        <div class="absolute inset-0" style="background:linear-gradient(to bottom, rgba(0,0,0,0.55), rgba(0,0,0,0.7));"></div>
    }
    else
    {
        <div class="absolute inset-0 bg-gradient-to-br from-black via-zinc-900 to-black"></div>
        <div class="absolute inset-0 opacity-30"
             style="background-image: radial-gradient(ellipse at 60% 50%, rgba(212,175,55,0.35) 0%, transparent 70%);">
        </div>
    }
    <div class="relative text-center px-4 max-w-3xl mx-auto py-12">
        @if (!string.IsNullOrEmpty(hero?.Eyebrow))
        {
            <p class="text-xs tracking-[0.5em] uppercase mb-3 font-semibold" style="color:@hero!.CorDestaque;">@hero.Eyebrow</p>
        }
        <h1 class="font-playfair text-3xl md:text-4xl font-bold leading-tight mb-3" style="color:@(hero?.CorTexto ?? "#FFFFFF");">
            @(hero?.Titulo) <span style="color:@(hero?.CorDestaque ?? "#D4AF37");">@(hero?.TituloDestaque)</span>
        </h1>
        @if (!string.IsNullOrEmpty(hero?.Subtitulo))
        {
            <p class="text-sm mb-6 leading-relaxed max-w-xl mx-auto" style="color:@hero!.CorTexto; opacity:0.7;">
                @hero.Subtitulo
            </p>
        }
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/catalogo" class="btn-gold px-10 py-3 text-sm tracking-widest uppercase">
                Explorar Coleção
            </a>
            <a href="/quiz" class="btn-gold-outline px-10 py-3 text-sm tracking-widest uppercase">
                Quiz Olfativo ✦
            </a>
        </div>
    </div>
</section>

@if (campanhas.Any())
{
    <section class="max-w-7xl mx-auto px-4 pt-12 pb-4">
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:1.25rem;">
            @foreach (var camp in campanhas)
            {
                <a href="@camp.Link" class="group" style="position:relative; display:flex; flex-direction:column; justify-content:flex-end; min-height:200px; overflow:hidden; border:1px solid rgba(212,175,55,0.2); text-decoration:none;">
                    @if (!string.IsNullOrEmpty(camp.ImagemUrl))
                    {
                        <div style="position:absolute; inset:0; background-image:url('@camp.ImagemUrl'); background-size:cover; background-position:center; transition:transform 0.5s;" class="group-hover:scale-105"></div>
                        <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0.25));"></div>
                    }
                    else
                    {
                        <div style="position:absolute; inset:0; background:linear-gradient(135deg, rgba(212,175,55,0.25), rgba(24,24,27,0.95));"></div>
                    }
                    <div style="position:relative; padding:1.5rem;">
                        <div class="font-playfair" style="font-size:1.5rem; font-weight:700; color:#fff; line-height:1.1;">@camp.Titulo</div>
                        @if (!string.IsNullOrEmpty(camp.Subtitulo))
                        {
                            <div style="color:rgba(255,255,255,0.75); font-size:0.85rem; margin-top:0.35rem;">@camp.Subtitulo</div>
                        }
                        <div class="text-gold" style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.15em; margin-top:0.75rem;">Ver coleção →</div>
                    </div>
                </a>
            }
        </div>
    </section>
}

@if (promocoes.Any())
{
    <section class="max-w-7xl mx-auto px-4 pt-12 pb-8">
        <div class="flex items-end justify-between mb-8">
            <div>
                <p class="text-gold text-xs tracking-[0.4em] uppercase mb-2">Ofertas por tempo limitado</p>
                <h2 class="font-playfair text-3xl font-bold flex items-center gap-3">
                    Promoções
                    <span style="background:linear-gradient(135deg,#D4AF37,#A08020); color:#000; font-size:0.7rem; padding:0.2rem 0.6rem; letter-spacing:0.1em; border-radius:2px; vertical-align:middle;">SALE</span>
                </h2>
            </div>
            <a href="/catalogo?ordenarPor=preco" class="text-gold/60 hover:text-gold text-xs tracking-widest uppercase transition-colors hidden md:block">Ver tudo →</a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            @foreach (var produto in promocoes)
            {
                <a href="/produto/@produto.Slug" class="produto-card">
                    <div class="produto-thumb mb-4">
                        <span class="selo-desconto">-@produto.PercentualDesconto%</span>
                        @if (!string.IsNullOrEmpty(produto.UrlImagemPrincipal))
                        {
                            <img src="@produto.UrlImagemPrincipal" alt="@produto.Nome" loading="lazy" onerror="this.onerror=null;this.src='/img/placeholder-produto.svg'" />
                        }
                        else
                        {
                            <span class="text-white/10 text-5xl font-playfair">G</span>
                        }
                    </div>
                    <div class="text-white/40 text-xs uppercase tracking-wider mb-1">@produto.Marca</div>
                    <h3 class="text-sm font-medium">@produto.Nome</h3>
                    <div class="mt-2 flex items-baseline gap-2">
                        <span class="text-white/30 text-xs line-through">de R$ @produto.Preco.ToString("N2")</span>
                    </div>
                    <div class="flex items-baseline gap-1.5">
                        <span class="text-gold/60 text-xs">por</span>
                        <span class="text-gold font-playfair text-xl font-bold">R$ @produto.PrecoPromo!.Value.ToString("N2")</span>
                    </div>
                </a>
            }
        </div>
    </section>
}

@if (destaques.Any())
{
    <section class="max-w-7xl mx-auto px-4 py-8">
        <div class="flex items-end justify-between mb-8">
            <div>
                <p class="text-gold text-xs tracking-[0.4em] uppercase mb-2">Seleção Especial</p>
                <h2 class="font-playfair text-3xl font-bold">Destaques</h2>
            </div>
            <a href="/catalogo" class="text-gold/60 hover:text-gold text-xs tracking-widest uppercase transition-colors hidden md:block">Ver tudo →</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            @foreach (var produto in destaques)
            {
                <a href="/produto/@produto.Slug" class="produto-card">
                    <div class="produto-thumb mb-4">
                        @if (produto.EmPromocao)
                        {
                            <span class="selo-desconto">-@produto.PercentualDesconto%</span>
                        }
                        @if (!string.IsNullOrEmpty(produto.UrlImagemPrincipal))
                        {
                            <img src="@produto.UrlImagemPrincipal" alt="@produto.Nome" loading="lazy" onerror="this.onerror=null;this.src='/img/placeholder-produto.svg'" />
                        }
                        else
                        {
                            <span class="text-white/10 text-5xl font-playfair">G</span>
                        }
                    </div>
                    <div class="text-white/40 text-xs uppercase tracking-wider mb-1">@produto.Marca</div>
                    <h3 class="text-sm font-medium">@produto.Nome</h3>
                    <div class="mt-2 flex items-center gap-2">
                        @if (produto.PrecoPromo.HasValue)
                        {
                            <span class="text-gold font-semibold">R$ @produto.PrecoPromo.Value.ToString("N2")</span>
                            <span class="text-white/30 text-xs line-through">R$ @produto.Preco.ToString("N2")</span>
                        }
                        else
                        {
                            <span class="text-white font-semibold">R$ @produto.Preco.ToString("N2")</span>
                        }
                    </div>
                </a>
            }
        </div>
        <div class="text-center mt-10">
            <a href="/catalogo" class="btn-gold-outline px-12 py-4 text-sm tracking-widest uppercase inline-block">Ver Todos os Produtos</a>
        </div>
    </section>
}

@if (categorias.Any())
{
    <section class="max-w-7xl mx-auto px-4 py-16">
        <div class="text-center mb-12">
            <p class="text-gold text-xs tracking-[0.4em] uppercase mb-3">Explore</p>
            <h2 class="font-playfair text-3xl font-bold">Nossas Categorias</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            @foreach (var cat in categorias.Take(4))
            {
                <a href="/catalogo?categoriaId=@cat.Id" class="group border border-gold/20 bg-zinc-900 hover:border-gold/60 transition-all duration-300 p-8 text-center block">
                    <div class="font-playfair text-xl font-semibold group-hover:text-gold transition-colors">@cat.Nome</div>
                    <div class="text-gold/0 group-hover:text-gold/60 text-xs tracking-widest uppercase mt-2 transition-all">Ver produtos →</div>
                </a>
            }
        </div>
    </section>
}

<section style="background:linear-gradient(135deg, rgba(212,175,55,0.08), rgba(9,9,11,0.8)); border-top:1px solid rgba(212,175,55,0.15); border-bottom:1px solid rgba(212,175,55,0.15);">
    <div class="max-w-4xl mx-auto px-4 py-16" style="text-align:center;">
        <p class="text-gold" style="font-size:0.65rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:0.75rem;">Descubra</p>
        <h2 class="font-playfair" style="font-size:2.5rem; font-weight:700; margin-bottom:1rem;">
            Qual é o seu <span class="text-gradient">perfume ideal</span>?
        </h2>
        <p style="color:rgba(255,255,255,0.5); margin-bottom:2rem; font-size:0.9375rem;">
            Responda 4 perguntas e receba recomendações personalizadas para o seu perfil olfativo.
        </p>
        <a href="/quiz" class="btn-gold" style="padding:0.875rem 2.5rem; font-size:0.875rem; letter-spacing:0.15em; text-transform:uppercase; display:inline-block;">
            Fazer Quiz ✦
        </a>
    </div>
</section>

<section class="max-w-3xl mx-auto px-4 py-16" style="text-align:center;">
    <p class="text-gold" style="font-size:0.65rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:0.75rem;">Exclusividades</p>
    <h2 class="font-playfair" style="font-size:2rem; font-weight:700; margin-bottom:0.75rem;">Fique por dentro das novidades</h2>
    <p style="color:rgba(255,255,255,0.4); margin-bottom:2rem; font-size:0.875rem;">Lançamentos, promoções e dicas de fragrâncias diretamente no seu e-mail.</p>
    @if (newsletterOk)
    {
        <div style="border:1px solid rgba(74,222,128,0.3); background:rgba(74,222,128,0.05); color:rgb(74,222,128); padding:0.75rem 1.25rem; margin-bottom:1rem; font-size:0.875rem; display:inline-block;">
            ✓ Obrigado! Você está inscrito na nossa newsletter.
        </div>
    }
    else
    {
        <form method="post" action="/newsletter/inscrever" style="display:flex; max-width:480px; margin:0 auto; gap:0;">
            @Html.AntiForgeryToken()
            <input type="email" name="email" placeholder="seu@email.com" required
                   style="flex:1; background:rgba(24,24,27,0.8); border:1px solid rgba(212,175,55,0.3); border-right:none; color:#fff; padding:0.75rem 1.25rem; font-size:0.875rem; outline:none;" />
            <button type="submit" class="btn-gold" style="padding:0.75rem 1.5rem; font-size:0.8rem; letter-spacing:0.08em; white-space:nowrap;">
                Inscrever
            </button>
        </form>
        <p style="color:rgba(255,255,255,0.2); font-size:0.7rem; margin-top:0.75rem;">Sem spam. Cancele quando quiser.</p>
    }
</section>

<section class="border-t border-gold/10 bg-zinc-950/80">
    <div class="max-w-7xl mx-auto px-4 py-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="py-4">
            <div class="text-gold text-2xl mb-2">✦</div>
            <div class="text-white text-sm font-semibold mb-1">Frete Grátis</div>
            <div class="text-white/40 text-xs">Acima de R$ 150 na cidade</div>
        </div>
        <div class="py-4">
            <div class="text-gold text-2xl mb-2">◈</div>
            <div class="text-white text-sm font-semibold mb-1">Retirada na Loja</div>
            <div class="text-white/40 text-xs">Sem custo adicional</div>
        </div>
        <div class="py-4">
            <div class="text-gold text-2xl mb-2">◇</div>
            <div class="text-white text-sm font-semibold mb-1">Pague na Entrega</div>
            <div class="text-white/40 text-xs">Dinheiro, cartão ou PIX</div>
        </div>
        <div class="py-4">
            <div class="text-gold text-2xl mb-2">✧</div>
            <div class="text-white text-sm font-semibold mb-1">Produtos Originais</div>
            <div class="text-white/40 text-xs">100% autênticos</div>
        </div>
    </div>
</section>
