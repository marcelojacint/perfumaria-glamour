@model IEnumerable<Glamour.Application.DTOs.ProdutoListagemDto>
@{
    ViewBag.Title = "Favoritos";
    var produtos = Model.ToList();
}

<div class="max-w-7xl mx-auto px-4 py-12">
    <div style="margin-bottom:2.5rem;">
        <p class="text-gold" style="font-size:0.65rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:0.5rem;">Minha Conta</p>
        <h1 class="font-playfair" style="font-size:2.5rem; font-weight:700;">Favoritos ♥</h1>
    </div>

    @if (!produtos.Any())
    {
        <div style="text-align:center; padding:5rem 0; color:rgba(255,255,255,0.3);">
            <div class="font-playfair" style="font-size:3.5rem; margin-bottom:1rem;">♡</div>
            <p style="margin-bottom:1rem;">Você ainda não adicionou favoritos.</p>
            <a href="/catalogo" class="btn-gold" style="padding:0.75rem 2rem; font-size:0.8rem; display:inline-block;">Explorar Catálogo</a>
        </div>
    }
    else
    {
        <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem;">
            @foreach (var p in produtos)
            {
                <div style="border:1px solid rgba(255,255,255,0.08); background:rgba(24,24,27,0.5); padding:1.25rem; display:flex; gap:1rem; align-items:center;">
                    <a href="/produto/@p.Slug" style="width:5rem; height:5rem; background:#18181b; flex-shrink:0; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                        @if (!string.IsNullOrEmpty(p.UrlImagemPrincipal))
                        {
                            <img src="@p.UrlImagemPrincipal" style="width:100%; height:100%; object-fit:cover;" />
                        }
                    </a>
                    <div style="flex:1; min-width:0;">
                        <div style="color:rgba(255,255,255,0.4); font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.2rem;">@p.Marca</div>
                        <a href="/produto/@p.Slug" style="font-size:0.875rem; font-weight:500; display:block; margin-bottom:0.35rem;">@p.Nome</a>
                        <div style="color:@(p.PrecoPromo.HasValue ? "#D4AF37" : "#fff"); font-weight:600; font-size:0.875rem;">
                            R$ @((p.PrecoPromo ?? p.Preco).ToString("N2"))
                        </div>
                    </div>
                    <div style="display:flex; flex-direction:column; gap:0.5rem;">
                        <form method="post" action="/carrinho/adicionar" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="produtoId" value="@p.Id" />
                            <input type="hidden" name="quantidade" value="1" />
                            <button type="submit" class="btn-gold" style="padding:0.4rem 0.875rem; font-size:0.7rem; white-space:nowrap;">+ Carrinho</button>
                        </form>
                        <form method="post" action="/favoritos/toggle/@p.Id" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="/favoritos" />
                            <button type="submit" style="background:none; border:none; cursor:pointer; color:rgba(248,113,113,0.6); font-size:0.7rem; width:100%;">Remover</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
