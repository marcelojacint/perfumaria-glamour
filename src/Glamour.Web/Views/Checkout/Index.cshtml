@model IEnumerable<Glamour.Domain.Interfaces.ItemCarrinho>
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    ViewBag.Title = "Checkout";
    var itens = Model.ToList();
    var subtotal = itens.Sum(i => i.Preco * i.Quantidade);
    var subtotalJs = subtotal.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var enderecos = (ViewBag.Enderecos as IEnumerable<Glamour.Application.DTOs.EnderecoDto> ?? []).ToList();
    var enderecoPrincipal = enderecos.FirstOrDefault(e => e.Principal) ?? enderecos.FirstOrDefault();
    var opcaoInicial = enderecoPrincipal != null ? enderecoPrincipal.Id.ToString() : "novo";

    var lojaNome = Config["Loja:Nome"] ?? "Glamour";
    var lojaEndereco = Config["Loja:EnderecoLoja"] ?? "";
    var lojaHorario = Config["Loja:HorarioFuncionamento"] ?? "";
    var lojaWhatsapp = Config["Loja:WhatsApp"] ?? "";
    var lojaTelefone = Config["Loja:Telefone"] ?? "";

    var telefoneCliente = ViewBag.TelefoneCliente as string ?? "";
    var temTelefone = !string.IsNullOrWhiteSpace(telefoneCliente);
}

<div class="max-w-5xl mx-auto px-4 py-12">
    <div class="mb-10">
        <p class="text-gold text-xs tracking-[0.4em] uppercase mb-2">Finalizar</p>
        <h1 class="font-playfair text-4xl font-bold">Checkout</h1>
    </div>

    @if (TempData["Erro"] != null)
    {
        <div style="border:1px solid rgba(248,113,113,0.4); background:rgba(127,29,29,0.15); color:rgb(248,113,113); padding:0.875rem 1.25rem; margin-bottom:1.5rem; font-size:0.875rem;">
            @TempData["Erro"]
        </div>
    }

    <form method="post" action="/checkout"
          x-data="checkout()" x-init="init()">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

            <div class="lg:col-span-2 space-y-8">

                <div class="border border-gold/20 bg-zinc-900/50 p-6">
                    <h2 class="font-playfair text-xl font-semibold mb-5">Telefone para contato</h2>
                    @if (!temTelefone)
                    {
                        <div style="border:1px solid rgba(251,191,36,0.4); background:rgba(120,53,15,0.15); color:rgb(251,191,36); padding:0.75rem 1rem; margin-bottom:1.25rem; font-size:0.8rem; display:flex; align-items:center; gap:0.5rem;">
                            <span style="font-size:1rem;">📱</span>
                            <span>Você ainda não tem um telefone cadastrado. Informe um para que possamos confirmar seu pedido.</span>
                        </div>
                    }
                    <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">Celular / WhatsApp</label>
                    <input type="tel" name="telefone" value="@telefoneCliente" required
                           placeholder="(83) 99999-9999" maxlength="16"
                           pattern="\(?\d{2}\)?\s?\d{4,5}-?\d{4}"
                           title="Informe um telefone válido com DDD. Ex.: (83) 99999-9999"
                           class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none" />
                    <p class="text-white/30 text-xs mt-1">Usaremos este número para confirmar o pedido e combinar a entrega ou retirada.</p>
                </div>

                <div class="border border-gold/20 bg-zinc-900/50 p-6">
                    <h2 class="font-playfair text-xl font-semibold mb-5">Como deseja receber?</h2>
                    <div class="grid grid-cols-2 gap-4">
                        <label class="cursor-pointer">
                            <input type="radio" name="tipoEntrega" value="Entrega"
                                   x-model="tipoEntrega" @@change="aoMudarEntrega()" class="sr-only" checked />
                            <div :class="tipoEntrega === 'Entrega' ? 'border-gold bg-gold/10' : 'border-white/20 hover:border-white/40'"
                                 class="border p-4 text-center transition-all">
                                <div class="text-2xl mb-2">🚚</div>
                                <div class="font-semibold text-sm">Entrega</div>
                                <div class="text-white/40 text-xs mt-1">Cacimba de Dentro e região</div>
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="tipoEntrega" value="RetiradaNaLoja"
                                   x-model="tipoEntrega" @@change="aoMudarEntrega()" class="sr-only" />
                            <div :class="tipoEntrega === 'RetiradaNaLoja' ? 'border-gold bg-gold/10' : 'border-white/20 hover:border-white/40'"
                                 class="border p-4 text-center transition-all">
                                <div class="text-2xl mb-2">🏪</div>
                                <div class="font-semibold text-sm">Retirada na Loja</div>
                                <div class="text-white/40 text-xs mt-1">Sem custo de frete</div>
                            </div>
                        </label>
                    </div>

                    <div x-show="tipoEntrega === 'Entrega'" x-transition class="mt-6 space-y-4">

                        @if (enderecos.Any())
                        {
                            <label class="text-xs text-gold/80 tracking-wider uppercase block mb-1">Endereços salvos</label>
                            <div class="space-y-3">
                                @foreach (var e in enderecos)
                                {
                                    <label class="cursor-pointer block">
                                        <input type="radio" name="enderecoId" value="@e.Id"
                                               data-cidade="@e.Cidade" data-uf="@e.UF"
                                               x-model="enderecoOpcao" @@change="aoSelecionarEndereco()" class="sr-only" />
                                        <div :class="enderecoOpcao === '@e.Id' ? 'border-gold bg-gold/10' : 'border-white/15 hover:border-white/30'"
                                             class="border p-4 transition-all flex items-start justify-between gap-3">
                                            <div class="text-sm">
                                                @if (e.Principal)
                                                {
                                                    <span class="text-gold text-xs uppercase tracking-wider block mb-1">Principal</span>
                                                }
                                                <div class="text-white">@e.Logradouro, @e.Numero @(string.IsNullOrEmpty(e.Complemento) ? "" : "- " + e.Complemento)</div>
                                                <div class="text-white/40 text-xs mt-0.5">@e.Bairro · @e.Cidade/@e.UF · CEP @e.CEP</div>
                                            </div>
                                            <span x-show="enderecoOpcao === '@e.Id'" class="text-gold">✓</span>
                                        </div>
                                    </label>
                                }
                                <label class="cursor-pointer block">
                                    <input type="radio" name="enderecoId" value="novo"
                                           x-model="enderecoOpcao" @@change="aoSelecionarEndereco()" class="sr-only" />
                                    <div :class="enderecoOpcao === 'novo' ? 'border-gold bg-gold/10' : 'border-white/15 hover:border-white/30'"
                                         class="border p-4 transition-all text-sm text-white/70 flex items-center gap-2">
                                        <span class="text-gold">+</span> Usar um novo endereço
                                    </div>
                                </label>
                            </div>
                        }

                        <div x-show="@(enderecos.Any() ? "enderecoOpcao === 'novo'" : "true")" x-transition
                             class="grid grid-cols-2 gap-4 pt-2">
                            <div class="col-span-2">
                                <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">
                                    CEP <span x-show="cepBuscando" class="text-white/30 normal-case tracking-normal">buscando...</span>
                                </label>
                                <input type="text" name="cep" placeholder="00000-000" maxlength="9"
                                       @@input="buscarCep($event.target.value)"
                                       class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none" />
                                <p class="text-white/30 text-xs mt-1">Digite o CEP para preencher o endereço automaticamente</p>
                            </div>
                            <div class="col-span-2">
                                <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">Logradouro</label>
                                <input type="text" name="logradouro" x-ref="logradouro"
                                       class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none" />
                            </div>
                            <div>
                                <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">Número</label>
                                <input type="text" name="numero" x-ref="numero"
                                       class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none" />
                            </div>
                            <div>
                                <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">Complemento</label>
                                <input type="text" name="complemento"
                                       class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none" />
                            </div>
                            <div>
                                <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">Bairro</label>
                                <input type="text" name="bairro" x-ref="bairro"
                                       class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none" />
                            </div>
                            <div>
                                <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">Cidade</label>
                                <input type="text" name="cidade" x-ref="cidade" @@change="aoSelecionarEndereco()"
                                       class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none" />
                            </div>
                            <div>
                                <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">Estado</label>
                                <input type="text" name="uf" x-ref="uf" maxlength="2" @@change="aoSelecionarEndereco()"
                                       class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none" />
                            </div>
                        </div>

                        <div x-show="freteCalculado && !dentroDaArea" x-transition
                             class="border border-amber-600/40 bg-amber-950/20 p-4 text-sm">
                            <p class="text-amber-400 font-semibold mb-1">📍 Fora da nossa área de entrega</p>
                            <p class="text-white/60 leading-relaxed mb-3" x-text="freteMensagem"></p>
                            @if (!string.IsNullOrEmpty(lojaWhatsapp))
                            {
                                <a href="https://wa.me/@lojaWhatsapp?text=Ol%C3%A1!%20Gostaria%20de%20saber%20sobre%20entrega%20para%20a%20minha%20regi%C3%A3o."
                                   target="_blank" class="inline-flex items-center gap-2 text-gold text-sm hover:underline">
                                    💬 Falar com a loja no WhatsApp
                                </a>
                            }
                        </div>
                    </div>

                    <div x-show="tipoEntrega === 'RetiradaNaLoja'" x-transition class="mt-6 border border-gold/20 bg-gold/5 p-4 text-sm text-white/70">
                        <p class="font-semibold text-gold mb-2">Endereço da Loja</p>
                        <a href="https://www.google.com/maps/search/?api=1&query=@(Uri.EscapeDataString(lojaEndereco))" target="_blank" rel="noopener" class="text-white/80 hover:text-gold transition-colors flex items-start gap-2">
                            <span class="text-gold">📍</span> <span>@lojaEndereco</span>
                        </a>
                        @if (!string.IsNullOrEmpty(lojaWhatsapp))
                        {
                            <a href="https://wa.me/@lojaWhatsapp" target="_blank" rel="noopener" class="text-white/80 hover:text-gold transition-colors flex items-center gap-2 mt-2">
                                <span class="text-gold">📱</span> @lojaTelefone
                            </a>
                        }
                        <p class="text-white/40 text-xs mt-2">@lojaHorario</p>
                    </div>
                </div>

                <div class="border border-gold/20 bg-zinc-900/50 p-6">
                    <h2 class="font-playfair text-xl font-semibold mb-5">Forma de Pagamento</h2>
                    <p class="text-white/40 text-sm mb-4">Informe como deseja pagar. O pagamento será realizado no momento da entrega ou retirada.</p>

                    <div style="border:1px solid rgba(74,222,128,0.3); background:rgba(74,222,128,0.05); padding:0.75rem 1rem; margin-bottom:1.25rem; font-size:0.8rem; color:rgb(74,222,128); display:flex; align-items:center; gap:0.5rem;">
                        <span style="font-size:1rem;">⚡</span>
                        <span><strong>PIX tem aprovação instantânea!</strong> Separe a chave PIX para pagar na hora da entrega.</span>
                    </div>

                    <div class="grid grid-cols-2 gap-3" x-data="{ metodo: 'Dinheiro' }">
                        @foreach (var (val, nome, icon) in new[] {
                            ("Dinheiro", "Dinheiro", "💵"),
                            ("CartaoCredito", "Crédito", "💳"),
                            ("CartaoDebito", "Débito", "💳"),
                            ("Pix", "PIX ⚡", "⚡")
                        })
                        {
                            <label class="cursor-pointer">
                                <input type="radio" name="metodoPagamento" value="@val.Split(' ')[0]"
                                       x-model="metodo" class="sr-only" @(val == "Dinheiro" ? "checked" : "") />
                                <div :class="metodo === '@val' ? 'border-gold bg-gold/10' : 'border-white/20 hover:border-white/40'"
                                     class="border p-3 text-center transition-all">
                                    <div class="text-xl mb-1">@icon</div>
                                    <div class="text-sm font-medium">@nome</div>
                                </div>
                            </label>
                        }
                    </div>
                </div>

                <div class="border border-gold/20 bg-zinc-900/50 p-6 space-y-4">
                    <div>
                        <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">Cupom de Desconto</label>
                        <input type="text" name="cupomCodigo" placeholder="CÓDIGO DO CUPOM"
                               class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none uppercase" />
                    </div>
                    <div>
                        <label class="text-xs text-gold/80 tracking-wider uppercase block mb-2">Observações</label>
                        <textarea name="observacoes" rows="3" placeholder="Observações sobre o pedido..."
                                  class="w-full bg-zinc-800 border border-white/10 text-white px-4 py-3 text-sm focus:border-gold/60 focus:outline-none resize-none"></textarea>
                    </div>
                </div>
            </div>

            <div>
                <div class="border border-gold/20 bg-zinc-900/50 p-6 sticky top-24">
                    <h2 class="font-playfair text-xl font-semibold mb-5">Resumo do Pedido</h2>
                    <div class="space-y-3 mb-5">
                        @foreach (var item in itens)
                        {
                            <div class="flex justify-between text-sm text-white/60">
                                <span>@item.Nome <span class="text-white/30">×@item.Quantidade</span></span>
                                <span class="text-white">R$ @((item.Preco * item.Quantidade).ToString("N2"))</span>
                            </div>
                        }
                    </div>
                    <div class="border-t border-white/10 pt-4 space-y-2 text-sm text-white/60 mb-5">
                        <div class="flex justify-between">
                            <span>Subtotal</span>
                            <span class="text-white">R$ @subtotal.ToString("N2")</span>
                        </div>
                        <div class="flex justify-between">
                            <span>Frete</span>
                            <span class="text-white" x-text="textoFrete()"></span>
                        </div>
                    </div>
                    <div class="border-t border-white/10 pt-4 flex justify-between font-semibold mb-6">
                        <span>Total</span>
                        <span class="text-gold text-lg" x-text="textoTotal()"></span>
                    </div>
                    <button type="submit" class="btn-gold w-full py-4 text-sm tracking-widest uppercase"
                            :disabled="bloqueado()"
                            :style="bloqueado() ? 'opacity:0.4; cursor:not-allowed;' : ''">
                        Confirmar Pedido
                    </button>
                    <p x-show="bloqueado()" class="text-amber-400/70 text-xs text-center mt-3">
                        Selecione um endereço dentro da área de entrega ou escolha retirada na loja.
                    </p>
                    <p class="text-white/20 text-xs text-center mt-4 leading-relaxed">
                        Pagamento na entrega ou retirada.<br/>
                        Seu pedido será confirmado por e-mail.
                    </p>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
<script>
function checkout() {
    return {
        tipoEntrega: 'Entrega',
        enderecoOpcao: '@opcaoInicial',
        cepBuscando: false,
        subtotal: @subtotalJs,
        freteCalculado: false,
        calculandoFrete: false,
        dentroDaArea: false,
        freteGratis: false,
        freteValor: 0,
        freteMensagem: '',

        init() {
            this.$nextTick(() => { if (this.tipoEntrega === 'Entrega') this.aoSelecionarEndereco(); });
        },

        aoMudarEntrega() {
            if (this.tipoEntrega === 'RetiradaNaLoja') {
                this.freteCalculado = false;
            } else {
                this.aoSelecionarEndereco();
            }
        },

        aoSelecionarEndereco() {
            if (this.tipoEntrega !== 'Entrega') return;
            if (this.enderecoOpcao === 'novo') {
                this.calcularFrete(this.$refs.cidade?.value, this.$refs.uf?.value);
            } else {
                const el = document.querySelector('input[name=enderecoId][value="' + this.enderecoOpcao + '"]');
                if (el) this.calcularFrete(el.dataset.cidade, el.dataset.uf);
            }
        },

        async buscarCep(cep) {
            cep = (cep || '').replace(/\D/g, '');
            if (cep.length !== 8) return;
            this.cepBuscando = true;
            try {
                const r = await fetch('https://viacep.com.br/ws/' + cep + '/json/');
                const d = await r.json();
                if (!d.erro) {
                    if (d.logradouro) this.$refs.logradouro.value = d.logradouro;
                    if (d.bairro) this.$refs.bairro.value = d.bairro;
                    if (d.localidade) this.$refs.cidade.value = d.localidade;
                    if (d.uf) this.$refs.uf.value = d.uf;
                    this.$refs.numero.focus();
                    this.calcularFrete(d.localidade || this.$refs.cidade.value, d.uf || this.$refs.uf.value);
                }
            } catch (e) {} finally { this.cepBuscando = false; }
        },

        async calcularFrete(cidade, uf) {
            if (!cidade || !uf) { this.freteCalculado = false; return; }
            this.calculandoFrete = true;
            try {
                const r = await fetch('/checkout/calcular-frete?cidade=' + encodeURIComponent(cidade) + '&uf=' + encodeURIComponent(uf));
                const d = await r.json();
                this.dentroDaArea = d.dentroDaArea;
                this.freteGratis = d.gratis;
                this.freteValor = d.valor;
                this.freteMensagem = d.mensagem;
                this.freteCalculado = true;
            } catch (e) { this.freteCalculado = false; }
            finally { this.calculandoFrete = false; }
        },

        freteAtual() {
            if (this.tipoEntrega === 'RetiradaNaLoja') return 0;
            if (this.freteCalculado && this.dentroDaArea) return this.freteValor;
            return 0;
        },

        textoFrete() {
            if (this.tipoEntrega === 'RetiradaNaLoja') return 'Grátis (retirada)';
            if (this.calculandoFrete) return 'calculando...';
            if (!this.freteCalculado) return 'Informe o endereço';
            if (!this.dentroDaArea) return 'Consultar loja';
            return this.freteGratis ? 'Grátis' : 'R$ ' + this.freteValor.toFixed(2).replace('.', ',');
        },

        textoTotal() {
            return 'R$ ' + (this.subtotal + this.freteAtual()).toFixed(2).replace('.', ',');
        },

        bloqueado() {
            return this.tipoEntrega === 'Entrega' && this.freteCalculado && !this.dentroDaArea;
        }
    };
}
</script>
}
