@model Glamour.Application.DTOs.PedidoDto
@{
    ViewBag.Title = $"Pedido #{Model.Id.ToString()[..8].ToUpper()}";
}

<div class="max-w-3xl mx-auto px-4 py-12">
    <div style="margin-bottom:2rem;">
        <a href="/conta/meus-pedidos" style="color:rgba(212,175,55,0.6); font-size:0.8rem;">← Meus Pedidos</a>
    </div>

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem;">
        <div>
            <p class="text-gold" style="font-size:0.65rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:0.25rem;">Pedido</p>
            <h1 class="font-playfair" style="font-size:2rem; font-weight:700;">#@Model.Id.ToString()[..8].ToUpper()</h1>
            <p style="color:rgba(255,255,255,0.4); font-size:0.8rem; margin-top:0.25rem;">@Model.CriadoEm.ToString("dd/MM/yyyy 'às' HH:mm")</p>
        </div>
        <span style="font-size:0.75rem; padding:0.35rem 1rem; border:1px solid; @(Model.Status == Glamour.Domain.Enums.StatusPedido.Entregue ? "border-color:rgba(74,222,128,0.5); color:rgb(74,222,128);" : Model.Status == Glamour.Domain.Enums.StatusPedido.Cancelado ? "border-color:rgba(248,113,113,0.5); color:rgb(248,113,113);" : "border-color:rgba(212,175,55,0.4); color:#D4AF37;")">
            @Model.Status
        </span>
    </div>

    <!-- Timeline de status -->
    @{
        var statusOrdem = new[] {
            Glamour.Domain.Enums.StatusPedido.Pendente,
            Glamour.Domain.Enums.StatusPedido.PagamentoAprovado,
            Glamour.Domain.Enums.StatusPedido.EmPreparacao,
            Glamour.Domain.Enums.StatusPedido.Enviado,
            Glamour.Domain.Enums.StatusPedido.Entregue
        };
        var statusAtualIdx = Array.IndexOf(statusOrdem, Model.Status);
    }
    @if (Model.Status != Glamour.Domain.Enums.StatusPedido.Cancelado)
    {
        <div style="border:1px solid rgba(255,255,255,0.08); background:rgba(24,24,27,0.5); padding:1.5rem; margin-bottom:1.5rem;">
            <div style="display:flex; justify-content:space-between; position:relative; padding-bottom:1rem;">
                @for (int i = 0; i < statusOrdem.Length; i++)
                {
                    var ativo = i <= statusAtualIdx;
                    <div style="text-align:center; flex:1; position:relative; z-index:1;">
                        <div style="width:1.5rem; height:1.5rem; border-radius:50%; border:2px solid; margin:0 auto 0.5rem; display:flex; align-items:center; justify-content:center; font-size:0.65rem; @(ativo ? "background:#D4AF37; border-color:#D4AF37; color:#000;" : "background:transparent; border-color:rgba(255,255,255,0.2); color:rgba(255,255,255,0.3);")">
                            @(ativo ? "✓" : (i + 1).ToString())
                        </div>
                        <div style="font-size:0.65rem; color:@(ativo ? "#D4AF37" : "rgba(255,255,255,0.3)"); text-transform:uppercase; letter-spacing:0.05em;">
                            @statusOrdem[i].ToString().Replace("PagamentoAprovado", "Aprovado").Replace("EmPreparacao", "Preparação")
                        </div>
                    </div>
                }
                <div style="position:absolute; top:0.75rem; left:10%; right:10%; height:2px; background:rgba(255,255,255,0.08); z-index:0;">
                    <div style="height:100%; background:#D4AF37; width:@(statusAtualIdx >= 1 ? (statusAtualIdx * 25) + "%" : "0%"); transition:width 0.5s;"></div>
                </div>
            </div>
        </div>
    }

    <div style="display:grid; grid-template-columns:2fr 1fr; gap:1.5rem;">
        <!-- Itens -->
        <div>
            <div style="border:1px solid rgba(255,255,255,0.08); background:rgba(24,24,27,0.5); padding:1.5rem; margin-bottom:1.5rem;">
                <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1.25rem;">Produtos</h2>
                @foreach (var item in Model.Itens)
                {
                    <div style="display:flex; justify-content:space-between; padding:0.6rem 0; border-bottom:1px solid rgba(255,255,255,0.05); font-size:0.875rem;">
                        <div>
                            <span style="color:rgba(255,255,255,0.8);">@item.NomeProduto</span>
                            <span style="color:rgba(255,255,255,0.4); margin-left:0.5rem;">×@item.Quantidade</span>
                        </div>
                        <span style="color:#D4AF37; font-weight:600;">R$ @item.Subtotal.ToString("N2")</span>
                    </div>
                }
                <div style="padding-top:1rem; display:flex; flex-direction:column; gap:0.375rem; font-size:0.8rem; color:rgba(255,255,255,0.5);">
                    <div style="display:flex; justify-content:space-between;"><span>Subtotal</span><span class="text-white">R$ @Model.Subtotal.ToString("N2")</span></div>
                    @if (Model.Desconto > 0) { <div style="display:flex; justify-content:space-between; color:rgb(74,222,128);"><span>Desconto</span><span>-R$ @Model.Desconto.ToString("N2")</span></div> }
                    <div style="display:flex; justify-content:space-between;"><span>Frete</span><span class="text-white">@(Model.Frete == 0 ? "Grátis" : $"R$ {Model.Frete:N2}")</span></div>
                    <div style="display:flex; justify-content:space-between; padding-top:0.5rem; border-top:1px solid rgba(255,255,255,0.08); font-weight:700; font-size:0.9rem;">
                        <span style="color:#fff;">Total</span><span style="color:#D4AF37;">R$ @Model.Total.ToString("N2")</span>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.CodigoRastreio))
            {
                <div style="border:1px solid rgba(212,175,55,0.2); background:rgba(212,175,55,0.05); padding:1rem; font-size:0.875rem;">
                    <p style="color:#D4AF37; font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.25rem;">Código de Rastreio</p>
                    <p style="font-family:monospace; font-size:1rem; color:#fff;">@Model.CodigoRastreio</p>
                </div>
            }
        </div>

        <!-- Info -->
        <div>
            <div style="border:1px solid rgba(255,255,255,0.08); background:rgba(24,24,27,0.5); padding:1.25rem; font-size:0.8rem; color:rgba(255,255,255,0.5);">
                <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1rem;">Detalhes</h2>
                <div style="display:flex; flex-direction:column; gap:0.5rem;">
                    <div><span style="color:rgba(255,255,255,0.3);">Entrega:</span> @(Model.TipoEntrega == Glamour.Domain.Enums.TipoEntrega.RetiradaNaLoja ? "Retirada na Loja" : "Entrega")</div>
                    <div><span style="color:rgba(255,255,255,0.3);">Pagamento:</span> @Model.MetodoPagamento</div>
                    @if (Model.CupomCodigo != null) { <div><span style="color:rgba(255,255,255,0.3);">Cupom:</span> @Model.CupomCodigo</div> }
                    @if (!string.IsNullOrEmpty(Model.Observacoes)) { <div><span style="color:rgba(255,255,255,0.3);">Obs:</span> @Model.Observacoes</div> }
                </div>
                @if (Model.Endereco != null)
                {
                    <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid rgba(255,255,255,0.08);">
                        <p style="color:rgba(255,255,255,0.3); margin-bottom:0.4rem;">Endereço de entrega:</p>
                        <p>@Model.Endereco.Logradouro, @Model.Endereco.Numero</p>
                        <p>@Model.Endereco.Cidade/@Model.Endereco.UF</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
