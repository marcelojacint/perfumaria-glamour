@model Glamour.Infrastructure.Identity.ApplicationUser
@{
    ViewBag.Title = "Meu Perfil";
    var enderecos = ViewBag.Enderecos as IEnumerable<Glamour.Application.DTOs.EnderecoDto> ?? [];
    int pontos = ViewBag.PontosLoyalty ?? 0;
    var nivelNome = pontos >= 5000 ? "Diamante" : pontos >= 2000 ? "Ouro" : pontos >= 500 ? "Prata" : "Bronze";
    var proximoNivel = pontos >= 5000 ? 5000 : pontos >= 2000 ? 5000 : pontos >= 500 ? 2000 : 500;
    var progresso = (int)Math.Min(100, (double)pontos / proximoNivel * 100);
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div style="margin-bottom:2.5rem;">
        <p class="text-gold" style="font-size:0.65rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:0.5rem;">Minha Conta</p>
        <h1 class="font-playfair" style="font-size:2.5rem; font-weight:700;">Perfil</h1>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div style="border:1px solid rgba(74,222,128,0.3); background:rgba(74,222,128,0.05); color:rgb(74,222,128); padding:0.75rem 1.25rem; margin-bottom:1.5rem; font-size:0.875rem;">@TempData["Sucesso"]</div>
    }
    @if (TempData["Erro"] != null)
    {
        <div style="border:1px solid rgba(248,113,113,0.3); background:rgba(248,113,113,0.05); color:rgb(248,113,113); padding:0.75rem 1.25rem; margin-bottom:1.5rem; font-size:0.875rem;">@TempData["Erro"]</div>
    }

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem;">
        <!-- Dados pessoais + Senha -->
        <div>
            <div style="border:1px solid rgba(212,175,55,0.2); background:rgba(24,24,27,0.5); padding:1.5rem; margin-bottom:1.5rem;">
                <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1.25rem;">Dados Pessoais</h2>
                <form method="post" action="/conta/perfil" style="display:flex; flex-direction:column; gap:1rem;">
                    @Html.AntiForgeryToken()
                    <div>
                        <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.35rem;">Nome</label>
                        <input type="text" name="nome" value="@Model.Nome" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                    </div>
                    <div>
                        <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.35rem;">Telefone</label>
                        <input type="tel" name="telefone" value="@Model.Telefone" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                    </div>
                    <div>
                        <label style="font-size:0.65rem; color:rgba(255,255,255,0.3); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.35rem;">E-mail (não editável)</label>
                        <div style="color:rgba(255,255,255,0.4); font-size:0.875rem; padding:0.5rem 0;">@Model.Email</div>
                    </div>
                    <button type="submit" class="btn-gold" style="padding:0.6rem 1.5rem; font-size:0.75rem; align-self:flex-start;">Salvar</button>
                </form>
            </div>

            <div style="border:1px solid rgba(255,255,255,0.08); background:rgba(24,24,27,0.5); padding:1.5rem;">
                <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1.25rem;">Alterar Senha</h2>
                <form method="post" action="/conta/alterar-senha" style="display:flex; flex-direction:column; gap:1rem;">
                    @Html.AntiForgeryToken()
                    <div>
                        <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.35rem;">Senha Atual</label>
                        <input type="password" name="SenhaAtual" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                    </div>
                    <div>
                        <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.35rem;">Nova Senha</label>
                        <input type="password" name="NovaSenha" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                    </div>
                    <div>
                        <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.35rem;">Confirmar Nova Senha</label>
                        <input type="password" name="ConfirmacaoNovaSenha" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                    </div>
                    <button type="submit" class="btn-gold-outline" style="padding:0.6rem 1.5rem; font-size:0.75rem; align-self:flex-start; display:inline-block;">Alterar Senha</button>
                </form>
            </div>
        </div>

        <!-- Pontos + Endereços -->
        <div>
            <!-- Programa de Fidelidade -->
            <div style="border:1px solid rgba(212,175,55,0.3); background:linear-gradient(135deg, rgba(212,175,55,0.08), rgba(24,24,27,0.5)); padding:1.5rem; margin-bottom:1.5rem;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
                    <div>
                        <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.25rem;">Programa Glamour ✦</h2>
                        <p style="color:rgba(255,255,255,0.5); font-size:0.8rem;">Nível: @nivelNome</p>
                    </div>
                    <div style="text-align:right;">
                        <div class="font-playfair" style="font-size:2rem; font-weight:700; color:#D4AF37;">@pontos</div>
                        <div style="color:rgba(255,255,255,0.4); font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em;">pontos</div>
                    </div>
                </div>
                <div style="display:flex; justify-content:space-between; font-size:0.7rem; color:rgba(255,255,255,0.4); margin-bottom:0.4rem;">
                    <span>@pontos pts</span>
                    <span>@proximoNivel pts para próximo nível</span>
                </div>
                <div style="background:rgba(255,255,255,0.08); height:4px; border-radius:2px; overflow:hidden;">
                    <div style="width:@progresso%; background:linear-gradient(90deg,#D4AF37,#F0D060); height:100%; border-radius:2px;"></div>
                </div>
                <p style="color:rgba(255,255,255,0.3); font-size:0.7rem; margin-top:0.75rem;">R$ 1 gasto = 1 ponto · 100 pontos = R$ 1 de desconto</p>
            </div>

            <!-- Endereços -->
            <div style="border:1px solid rgba(255,255,255,0.08); background:rgba(24,24,27,0.5); padding:1.5rem;">
                <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1.25rem;">Endereços</h2>
                @if (enderecos.Any())
                {
                    <div style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1.25rem;">
                        @foreach (var e in enderecos)
                        {
                            <div style="border:1px solid @(e.Principal ? "rgba(212,175,55,0.4)" : "rgba(255,255,255,0.07)"); padding:0.875rem; font-size:0.8rem;">
                                @if (e.Principal) { <span style="font-size:0.65rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.35rem;">Principal</span> }
                                <div style="color:rgba(255,255,255,0.8);">@e.Logradouro, @e.Numero</div>
                                <div style="color:rgba(255,255,255,0.4);">@e.Cidade/@e.UF · CEP @e.CEP</div>
                                @if (!e.Principal)
                                {
                                    <form method="post" action="/conta/enderecos/principal/@e.Id" style="margin-top:0.5rem;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" style="background:none; border:none; color:rgba(212,175,55,0.6); font-size:0.7rem; cursor:pointer; padding:0;">Definir como principal</button>
                                    </form>
                                }
                            </div>
                        }
                    </div>
                }
                <details>
                    <summary style="cursor:pointer; color:rgba(212,175,55,0.7); font-size:0.8rem; list-style:none;">+ Adicionar endereço</summary>
                    <form method="post" action="/conta/enderecos/adicionar" style="margin-top:1rem; display:flex; flex-direction:column; gap:0.75rem;">
                        @Html.AntiForgeryToken()
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
                            <div><label style="font-size:0.65rem; color:rgba(212,175,55,0.5); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.3rem;">CEP</label><input type="text" name="CEP" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.45rem 0.6rem; font-size:0.8rem; box-sizing:border-box;" /></div>
                            <div><label style="font-size:0.65rem; color:rgba(212,175,55,0.5); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.3rem;">Número</label><input type="text" name="Numero" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.45rem 0.6rem; font-size:0.8rem; box-sizing:border-box;" /></div>
                        </div>
                        <div><label style="font-size:0.65rem; color:rgba(212,175,55,0.5); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.3rem;">Logradouro</label><input type="text" name="Logradouro" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.45rem 0.6rem; font-size:0.8rem; box-sizing:border-box;" /></div>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
                            <div><label style="font-size:0.65rem; color:rgba(212,175,55,0.5); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.3rem;">Cidade</label><input type="text" name="Cidade" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.45rem 0.6rem; font-size:0.8rem; box-sizing:border-box;" /></div>
                            <div><label style="font-size:0.65rem; color:rgba(212,175,55,0.5); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.3rem;">UF</label><input type="text" name="UF" maxlength="2" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.45rem 0.6rem; font-size:0.8rem; box-sizing:border-box;" /></div>
                        </div>
                        <div><label style="font-size:0.65rem; color:rgba(212,175,55,0.5); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.3rem;">Bairro</label><input type="text" name="Bairro" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.45rem 0.6rem; font-size:0.8rem; box-sizing:border-box;" /></div>
                        <button type="submit" class="btn-gold" style="padding:0.5rem 1.25rem; font-size:0.75rem; align-self:flex-start;">Adicionar</button>
                    </form>
                </details>
            </div>
        </div>
    </div>

    <div style="display:flex; gap:1.5rem; margin-top:2rem; padding-top:1.5rem; border-top:1px solid rgba(255,255,255,0.05);">
        <a href="/conta/meus-pedidos" style="color:rgba(255,255,255,0.5); font-size:0.8rem;">Meus Pedidos</a>
        <a href="/favoritos" style="color:rgba(255,255,255,0.5); font-size:0.8rem;">Favoritos</a>
    </div>
</div>
