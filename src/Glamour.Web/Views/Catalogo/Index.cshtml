@{
    ViewBag.Title = "Catálogo";
    var produtos = ViewBag.Produtos as IEnumerable<Glamour.Application.DTOs.ProdutoListagemDto> ?? [];
    var categorias = ViewBag.Categorias as IEnumerable<Glamour.Application.DTOs.CategoriaDto> ?? [];
    int total = ViewBag.Total ?? 0;
    int paginaAtual = ViewBag.PaginaAtual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;

    var genero = Context.Request.Query["genero"].ToString();
    var tema = genero switch
    {
        "Feminino" => "tema-feminino",
        "Masculino" => "tema-masculino",
        "Unissex" => "tema-unissex",
        _ => "tema-unissex"
    };
    var (heroTitulo, heroSub) = genero switch
    {
        "Feminino" => ("Feminino", "Florais, doces e marcantes — fragrâncias que celebram a feminilidade."),
        "Masculino" => ("Masculino", "Amadeirados, intensos e sofisticados — para o homem que marca presença."),
        "Unissex" => ("Unissex", "Composições versáteis que transcendem qualquer estilo."),
        _ => ("Catálogo", "Toda a coleção Glamour de perfumes e acessórios.")
    };
    bool temGenero = !string.IsNullOrEmpty(genero);
}

<div class="@tema">

    <section class="hero-genero">
        <div class="max-w-7xl mx-auto px-4 py-14 text-center">
            <p class="text-accent text-xs tracking-[0.5em] uppercase mb-3 font-semibold">@(temGenero ? "Coleção" : "Explore")</p>
            <h1 class="font-playfair text-4xl md:text-5xl font-bold mb-3">
                <span class="accent-gradient-text">@heroTitulo</span>
            </h1>
            <p class="text-white/55 text-sm max-w-xl mx-auto">@heroSub</p>

            <div class="flex flex-wrap items-center justify-center gap-3 mt-7">
                @foreach (var (val, lbl) in new[] { ("", "Todos"), ("Feminino", "Feminino"), ("Masculino", "Masculino"), ("Unissex", "Unissex") })
                {
                    var ativo = genero == val;
                    <a href="/catalogo@(string.IsNullOrEmpty(val) ? "" : "?genero=" + val)"
                       class="px-5 py-2 text-xs tracking-widest uppercase transition-all @(ativo ? "genero-chip" : "border border-white/15 text-white/50 hover:border-white/35 hover:text-white/80")"
                       style="border-radius:2px;">
                        @lbl
                    </a>
                }
            </div>
        </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 py-12">
        <p class="text-white/40 text-sm mb-8">@total produto(s) encontrado(s)</p>

        <div class="flex flex-col lg:flex-row gap-10">

            <aside class="lg:w-64 flex-shrink-0">
                <form method="get" action="/catalogo" class="space-y-8">
                    <div>
                        <label class="text-accent text-xs tracking-widest uppercase block mb-3">Busca</label>
                        <input type="text" name="busca" value="@Context.Request.Query["busca"]"
                               placeholder="Marca, nome..."
                               class="w-full bg-zinc-900 border border-white/10 text-white px-4 py-2 text-sm focus:outline-none" />
                    </div>

                    <div>
                        <label class="text-accent text-xs tracking-widest uppercase block mb-3">Categoria</label>
                        <select name="categoriaId" class="w-full bg-zinc-900 border border-white/10 text-white px-4 py-2 text-sm focus:outline-none">
                            <option value="">Todas</option>
                            @foreach (var cat in categorias)
                            {
                                <option value="@cat.Id" selected="@(Context.Request.Query["categoriaId"].ToString() == cat.Id.ToString())">@cat.Nome</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="text-accent text-xs tracking-widest uppercase block mb-3">Gênero</label>
                        @foreach (var g in new[] { "Feminino", "Masculino", "Unissex" })
                        {
                            <label class="flex items-center gap-2 mb-2 cursor-pointer group">
                                <input type="radio" name="genero" value="@g" checked="@(genero == g)" class="accent-amber-400" />
                                <span class="text-sm text-white/60 group-hover:text-white transition-colors">@g</span>
                            </label>
                        }
                        <label class="flex items-center gap-2 cursor-pointer group">
                            <input type="radio" name="genero" value="" checked="@(string.IsNullOrEmpty(genero))" class="accent-amber-400" />
                            <span class="text-sm text-white/60 group-hover:text-white transition-colors">Todos</span>
                        </label>
                    </div>

                    <div>
                        <label class="text-accent text-xs tracking-widest uppercase block mb-3">Ordenar por</label>
                        <select name="ordenarPor" class="w-full bg-zinc-900 border border-white/10 text-white px-4 py-2 text-sm focus:outline-none">
                            <option value="novo">Mais Novos</option>
                            <option value="preco" selected="@(Context.Request.Query["ordenarPor"] == "preco")">Menor Preço</option>
                            <option value="nome" selected="@(Context.Request.Query["ordenarPor"] == "nome")">Nome A-Z</option>
                        </select>
                    </div>

                    <button type="submit" class="btn-accent w-full py-3 text-sm tracking-widest uppercase">Filtrar</button>
                    <a href="/catalogo" class="block text-center text-white/40 hover:text-white text-xs py-2 transition-colors">Limpar filtros</a>
                </form>
            </aside>

            <div class="flex-1">
                @if (!produtos.Any())
                {
                    <div class="text-center py-20 text-white/30">
                        <div class="text-5xl mb-4 font-playfair accent-gradient-text">✦</div>
                        <p>Nenhum produto encontrado.</p>
                        <a href="/catalogo" class="text-accent hover:underline text-sm mt-2 inline-block">Limpar filtros</a>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
                        @foreach (var produto in produtos)
                        {
                            <a href="/produto/@produto.Slug" class="produto-card">
                                <div class="produto-thumb mb-3">
                                    @if (produto.EmPromocao)
                                    {
                                        <span class="selo-desconto">-@produto.PercentualDesconto%</span>
                                    }
                                    else if (produto.Destaque)
                                    {
                                        <span class="selo-desconto">DESTAQUE</span>
                                    }
                                    @if (!string.IsNullOrEmpty(produto.UrlImagemPrincipal))
                                    {
                                        <img src="@produto.UrlImagemPrincipal" alt="@produto.Nome" loading="lazy" />
                                    }
                                    else
                                    {
                                        <span class="text-white/10 text-4xl font-playfair">G</span>
                                    }
                                </div>
                                <div class="text-white/40 text-xs uppercase tracking-wider mb-1">@produto.Marca @(produto.Volume != null ? $"· {produto.Volume}" : "")</div>
                                <h3 class="text-sm font-medium">@produto.Nome</h3>
                                <div class="mt-1 flex items-center gap-2">
                                    @if (produto.PrecoPromo.HasValue)
                                    {
                                        <span class="text-accent font-semibold">R$ @produto.PrecoPromo.Value.ToString("N2")</span>
                                        <span class="text-white/30 text-xs line-through">R$ @produto.Preco.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-white font-semibold text-sm">R$ @produto.Preco.ToString("N2")</span>
                                    }
                                </div>
                                @if (produto.Estoque == 0)
                                {
                                    <span class="text-red-400/70 text-xs mt-1 block">Sem estoque</span>
                                }
                            </a>
                        }
                    </div>

                    @if (totalPaginas > 1)
                    {
                        <div class="flex justify-center gap-2 mt-12">
                            @for (int p = 1; p <= totalPaginas; p++)
                            {
                                var active = p == paginaAtual;
                                <a href="?@Context.Request.QueryString.Value&pagina=@p"
                                   class="w-10 h-10 flex items-center justify-center border text-sm transition-colors @(active ? "border-accent bg-accent text-black font-bold" : "border-white/20 text-white/60 hover:text-white")">
                                    @p
                                </a>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
