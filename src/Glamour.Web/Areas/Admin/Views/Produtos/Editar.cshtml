@model Glamour.Application.DTOs.AtualizarProdutoDto
@{
    ViewBag.Title = "Editar Produto";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var categorias = ViewBag.Categorias as IEnumerable<Glamour.Application.DTOs.CategoriaDto> ?? [];
    var imagens = ViewBag.Imagens as IEnumerable<Glamour.Application.DTOs.ProdutoImagemDto> ?? [];
}

@if (TempData["Sucesso"] != null) {
    <div style="border:1px solid rgba(74,222,128,0.3); background:rgba(74,222,128,0.05); color:rgb(74,222,128); padding:0.75rem 1rem; margin-bottom:1.5rem; font-size:0.875rem;">@TempData["Sucesso"]</div>
}
@if (TempData["Erro"] != null) {
    <div style="border:1px solid rgba(248,113,113,0.4); background:rgba(127,29,29,0.1); color:rgb(248,113,113); padding:0.75rem 1rem; margin-bottom:1.5rem; font-size:0.875rem;">@TempData["Erro"]</div>
}

<div style="display:grid; grid-template-columns:2fr 1fr; gap:2rem; max-width:1000px;">

    <div>
        <form method="post" action="/admin/produtos/editar" style="display:flex; flex-direction:column; gap:1.25rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="border:1px solid rgba(248,113,113,0.4); background:rgba(127,29,29,0.2); color:rgb(248,113,113); padding:0.75rem 1rem; font-size:0.875rem;">
                    @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors)) { <div>@e.ErrorMessage</div> }
                </div>
            }

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">
                @{ Campo("Nome", "Nome", Model.Nome?.ToString()); }
                @{ Campo("Slug (URL)", "Slug", Model.Slug?.ToString()); }
            </div>

            <div>
                <label style="font-size:0.7rem; color:rgba(212,175,55,0.7); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.4rem;">Descrição</label>
                <textarea name="Descricao" rows="4" required style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem 0.75rem; font-size:0.875rem; resize:vertical; box-sizing:border-box;">@Model.Descricao</textarea>
            </div>

            <div x-data="{ preco: '@(Model.Preco.ToString(System.Globalization.CultureInfo.InvariantCulture))', promo: '@(Model.PrecoPromo?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")' }">
                <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.25rem;">
                    <div>
                        <label style="font-size:0.7rem; color:rgba(212,175,55,0.7); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.4rem;">Preço (R$)</label>
                        <input type="number" name="Preco" step="0.01" required value="@Model.Preco.ToString(System.Globalization.CultureInfo.InvariantCulture)" @@input="preco = $event.target.value"
                               style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                    </div>
                    <div>
                        <label style="font-size:0.7rem; color:rgba(212,175,55,0.7); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.4rem;">Promoção (R$)</label>
                        <div style="display:flex; gap:0.4rem;">
                            <input type="number" name="PrecoPromo" step="0.01" placeholder="Sem promoção" x-ref="promoInput"
                                   value="@(Model.PrecoPromo?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")" @@input="promo = $event.target.value"
                                   style="flex:1; min-width:0; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                            <button type="button" x-show="promo" @@click="promo = ''; $refs.promoInput.value = ''" title="Remover promoção"
                                    style="background:none; border:1px solid rgba(248,113,113,0.4); color:rgba(248,113,113,0.8); padding:0 0.6rem; cursor:pointer; font-size:0.9rem;">×</button>
                        </div>
                    </div>
                    <div>
                        <label style="font-size:0.7rem; color:rgba(212,175,55,0.7); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.4rem;">Estoque</label>
                        <input type="number" name="Estoque" required value="@Model.Estoque.ToString()"
                               style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                    </div>
                </div>
                <div x-show="promo && parseFloat(promo) > 0 && parseFloat(promo) < parseFloat(preco)" x-transition
                     style="margin-top:0.75rem; border:1px solid rgba(212,175,55,0.3); background:rgba(212,175,55,0.06); padding:0.6rem 0.875rem; font-size:0.8rem; display:flex; align-items:center; gap:0.75rem;">
                    <span style="background:linear-gradient(135deg,#D4AF37,#A08020); color:#000; font-weight:700; padding:0.15rem 0.5rem; border-radius:2px;"
                          x-text="'-' + Math.round((1 - parseFloat(promo) / parseFloat(preco)) * 100) + '%'"></span>
                    <span style="color:rgba(255,255,255,0.5);">De <span style="text-decoration:line-through;" x-text="'R$ ' + parseFloat(preco||0).toFixed(2)"></span>
                        por <span style="color:#D4AF37; font-weight:600;" x-text="'R$ ' + parseFloat(promo||0).toFixed(2)"></span></span>
                    <span style="color:rgba(255,255,255,0.35); margin-left:auto;">ativo nas Promoções</span>
                </div>
                <p x-show="!promo" style="margin-top:0.5rem; font-size:0.72rem; color:rgba(255,255,255,0.3);">
                    Promoção desativada — o produto é vendido pelo preço normal. Informe um valor para reativar.
                </p>
            </div>

            <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.25rem;">
                @{ Campo("Marca", "Marca", Model.Marca?.ToString()); }
                @{ Campo("Volume", "Volume", Model.Volume?.ToString(), "text", false); }
                <div>
                    <label style="font-size:0.7rem; color:rgba(212,175,55,0.7); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.4rem;">Gênero</label>
                    <select name="Genero" style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem 0.75rem; font-size:0.875rem;">
                        @foreach (var g in new[] { "Feminino", "Masculino", "Unissex" }) {
                            <option value="@g" selected="@(Model.Genero == g)">@g</option>
                        }
                    </select>
                </div>
            </div>

            <div style="display:grid; grid-template-columns:2fr 1fr; gap:1.25rem; align-items:end;">
                <div>
                    <label style="font-size:0.7rem; color:rgba(212,175,55,0.7); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.4rem;">Categoria</label>
                    <select name="CategoriaId" required style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem 0.75rem; font-size:0.875rem;">
                        @foreach (var cat in categorias) {
                            <option value="@cat.Id" selected="@(Model.CategoriaId == cat.Id)">@cat.Nome</option>
                        }
                    </select>
                </div>
                <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer; padding-bottom:0.6rem;">
                    <input type="checkbox" name="Destaque" value="true" checked="@Model.Destaque" style="accent-color:#D4AF37;" />
                    <span style="font-size:0.875rem; color:rgba(255,255,255,0.7);">Destaque</span>
                </label>
            </div>

            <div style="display:flex; gap:1rem; padding-top:0.5rem;">
                <button type="submit" class="btn-gold" style="padding:0.75rem 2rem; font-size:0.8rem;">Salvar Alterações</button>
                <a href="/admin/produtos" style="padding:0.75rem 1.5rem; border:1px solid rgba(255,255,255,0.2); color:rgba(255,255,255,0.5); text-decoration:none; font-size:0.8rem;">Cancelar</a>
            </div>
        </form>
    </div>

    <div>
        <div style="border:1px solid rgba(212,175,55,0.2); background:rgba(24,24,27,0.5); padding:1.25rem;">
            <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1rem;">Imagens (@imagens.Count())</h3>

            @if (imagens.Any())
            {
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.5rem; margin-bottom:1rem;">
                    @foreach (var img in imagens.OrderBy(i => i.Ordem))
                    {
                        <div style="position:relative; border:1px solid @(img.Principal ? "rgba(212,175,55,0.6)" : "rgba(255,255,255,0.08)");">
                            <img src="@img.Url" style="width:100%; aspect-ratio:1; object-fit:cover; display:block;" loading="lazy" />
                            @if (img.Principal)
                            {
                                <span style="position:absolute; top:2px; left:2px; background:#D4AF37; color:#000; font-size:0.55rem; padding:1px 4px; font-weight:700; letter-spacing:0.05em;">PRINCIPAL</span>
                            }
                        </div>
                    }
                </div>
            }

            <form method="post" action="/admin/imagens/upload/@Model.Id" enctype="multipart/form-data" style="margin-bottom:0.75rem;">
                @Html.AntiForgeryToken()
                <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.4rem;">Upload de arquivo</label>
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                    <input type="file" name="arquivo" accept="image/*" required
                           style="flex:1; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.4rem 0.5rem; font-size:0.75rem; min-width:0;" />
                    <label style="display:flex; align-items:center; gap:0.3rem; font-size:0.72rem; color:rgba(255,255,255,0.5); cursor:pointer; white-space:nowrap;">
                        <input type="checkbox" name="principal" value="true" style="accent-color:#D4AF37;" /> Principal
                    </label>
                    <button type="submit" class="btn-gold" style="padding:0.4rem 0.875rem; font-size:0.72rem; white-space:nowrap;">Enviar</button>
                </div>
                <p style="font-size:0.65rem; color:rgba(255,255,255,0.25); margin-top:0.3rem;">JPG, PNG, WebP · máx. 5 MB</p>
            </form>

            <form method="post" action="/admin/imagens/url/@Model.Id">
                @Html.AntiForgeryToken()
                <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.4rem;">Ou adicionar por URL</label>
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                    <input type="url" name="url" placeholder="https://..." required
                           style="flex:1; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.4rem 0.5rem; font-size:0.75rem; min-width:0;" />
                    <label style="display:flex; align-items:center; gap:0.3rem; font-size:0.72rem; color:rgba(255,255,255,0.5); cursor:pointer; white-space:nowrap;">
                        <input type="checkbox" name="principal" value="true" style="accent-color:#D4AF37;" /> Principal
                    </label>
                    <button type="submit" class="btn-gold" style="padding:0.4rem 0.875rem; font-size:0.72rem; white-space:nowrap;">Adicionar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@{
    void Campo(string label, string name, string? valor, string type = "text", bool required = true)
    {
        <div>
            <label style="font-size:0.7rem; color:rgba(212,175,55,0.7); text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.4rem;">@label</label>
            <input type="@type" name="@name" value="@valor" required="@required"
                   style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
        </div>;
    }
}
