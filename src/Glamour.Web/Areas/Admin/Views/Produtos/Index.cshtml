@{
    ViewBag.Title = "Produtos";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var produtos = ViewBag.Produtos as IEnumerable<Glamour.Application.DTOs.ProdutoListagemDto> ?? [];
    int total = ViewBag.Total ?? 0;
    int paginaAtual = ViewBag.PaginaAtual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
    <div>
        <p style="color:rgba(255,255,255,0.4); font-size:0.8rem; margin:0;">@total produto(s) no sistema</p>
    </div>
    <a href="/admin/produtos/criar" class="btn-gold" style="padding:0.5rem 1.25rem; font-size:0.75rem;">+ Novo Produto</a>
</div>

<form method="get" style="margin-bottom:1.5rem; display:flex; gap:1rem;">
    <input type="text" name="busca" value="@Context.Request.Query["busca"]" placeholder="Buscar produto..."
           style="flex:1; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 1rem; font-size:0.875rem;" />
    <button type="submit" class="btn-gold" style="padding:0.5rem 1.25rem; font-size:0.75rem;">Buscar</button>
</form>

<div style="border:1px solid rgba(255,255,255,0.08); overflow:hidden;">
    <table style="width:100%; border-collapse:collapse; font-size:0.875rem;">
        <thead>
            <tr style="background:rgba(212,175,55,0.05); border-bottom:1px solid rgba(255,255,255,0.08);">
                <th style="text-align:left; padding:0.75rem 1rem; color:rgba(212,175,55,0.7); font-weight:600; font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase;">Produto</th>
                <th style="text-align:left; padding:0.75rem 1rem; color:rgba(212,175,55,0.7); font-weight:600; font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase;">Marca</th>
                <th style="text-align:right; padding:0.75rem 1rem; color:rgba(212,175,55,0.7); font-weight:600; font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase;">Preço</th>
                <th style="text-align:right; padding:0.75rem 1rem; color:rgba(212,175,55,0.7); font-weight:600; font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase;">Estoque</th>
                <th style="text-align:center; padding:0.75rem 1rem; color:rgba(212,175,55,0.7); font-weight:600; font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in produtos)
            {
                <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
                    <td style="padding:0.75rem 1rem;">
                        <div style="font-weight:500;">@p.Nome</div>
                        @if (p.Destaque) {
                            <span style="background:rgba(212,175,55,0.2); color:#D4AF37; font-size:0.6rem; padding:0.1rem 0.4rem; letter-spacing:0.1em; text-transform:uppercase;">Destaque</span>
                        }
                    </td>
                    <td style="padding:0.75rem 1rem; color:rgba(255,255,255,0.5);">@p.Marca</td>
                    <td style="padding:0.75rem 1rem; text-align:right;">
                        @if (p.PrecoPromo.HasValue) {
                            <span style="color:#D4AF37;">R$ @p.PrecoPromo.Value.ToString("N2")</span>
                            <span style="color:rgba(255,255,255,0.3); font-size:0.75rem; text-decoration:line-through; margin-left:0.25rem;">@p.Preco.ToString("N2")</span>
                        } else {
                            <span>R$ @p.Preco.ToString("N2")</span>
                        }
                    </td>
                    <td style="padding:0.75rem 1rem; text-align:right;">
                        <span style="color:@(p.Estoque > 0 ? "rgba(74,222,128,0.8)" : "rgba(248,113,113,0.8)");">@p.Estoque</span>
                    </td>
                    <td style="padding:0.75rem 1rem; text-align:center;">
                        <div style="display:flex; gap:0.75rem; justify-content:center;">
                            <a href="/produto/@p.Slug" target="_blank" style="color:rgba(255,255,255,0.4); font-size:0.75rem; text-decoration:none;">Ver</a>
                            <a href="/admin/produtos/editar/@p.Id" style="color:#D4AF37; font-size:0.75rem; text-decoration:none;">Editar</a>
                            <form method="post" action="/admin/produtos/remover/@p.Id" style="display:inline;" onsubmit="return confirm('Desativar este produto?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background:none; border:none; cursor:pointer; color:rgba(248,113,113,0.7); font-size:0.75rem;">Desativar</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (totalPaginas > 1)
{
    <div style="display:flex; justify-content:center; gap:0.5rem; margin-top:1.5rem;">
        @for (int p = 1; p <= totalPaginas; p++) {
            <a href="?pagina=@p&busca=@Context.Request.Query["busca"]"
               style="width:2rem; height:2rem; display:flex; align-items:center; justify-content:center; border:1px solid; font-size:0.8rem; text-decoration:none; @(p == paginaAtual ? "border-color:#D4AF37; background:rgba(212,175,55,0.2); color:#D4AF37;" : "border-color:rgba(255,255,255,0.1); color:rgba(255,255,255,0.5);")">@p</a>
        }
    </div>
}
