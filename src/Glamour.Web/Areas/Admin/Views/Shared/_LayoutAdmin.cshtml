<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - @(ViewBag.Title ?? "Glamour")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="bg-zinc-950 text-white font-inter" style="display:flex; min-height:100vh;">

    <!-- Sidebar -->
    <aside style="width:240px; flex-shrink:0; background:#09090b; border-right:1px solid rgba(212,175,55,0.15); padding:1.5rem 0; display:flex; flex-direction:column;">
        <div style="padding:0 1.5rem 1.5rem; border-bottom:1px solid rgba(255,255,255,0.05);">
            <a href="/" style="text-decoration:none;">
                <span class="font-playfair text-gradient" style="font-size:1.5rem; font-weight:700;">Glamour</span>
            </a>
            <div style="color:rgba(212,175,55,0.5); font-size:0.65rem; letter-spacing:0.3em; text-transform:uppercase; margin-top:2px;">Painel Admin</div>
        </div>

        <nav style="padding:1rem 0; flex:1;">
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                string NavClass(string c) => ctrl == c
                    ? "admin-nav-item active"
                    : "admin-nav-item";
            }
            <a href="/admin" class="@NavClass("Dashboard")">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Dashboard
            </a>
            <a href="/admin/produtos" class="@NavClass("Produtos")">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Produtos
            </a>
            <a href="/admin/categorias" class="@NavClass("Categorias")">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                Categorias
            </a>
            <a href="/admin/pedidos" class="@NavClass("Pedidos")">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                Pedidos
            </a>
        </nav>

        <div style="padding:1rem 1.5rem; border-top:1px solid rgba(255,255,255,0.05);">
            <a href="/" style="color:rgba(255,255,255,0.4); font-size:0.75rem; text-decoration:none; display:flex; align-items:center; gap:0.5rem;">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Ver Loja
            </a>
        </div>
    </aside>

    <!-- Conteúdo -->
    <div style="flex:1; display:flex; flex-direction:column; overflow-x:hidden;">
        <!-- Header Admin -->
        <header style="border-bottom:1px solid rgba(255,255,255,0.05); padding:1rem 2rem; display:flex; align-items:center; justify-content:space-between; background:rgba(9,9,11,0.8);">
            <h1 class="font-playfair" style="font-size:1.25rem; font-weight:600; margin:0;">@(ViewBag.Title ?? "Dashboard")</h1>
            <div style="display:flex; align-items:center; gap:1rem; font-size:0.75rem; color:rgba(255,255,255,0.4);">
                <span>@User.Identity?.Name</span>
                <form method="post" action="/conta/logout" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" style="color:rgba(212,175,55,0.6); background:none; border:none; cursor:pointer; font-size:0.75rem;">Sair</button>
                </form>
            </div>
        </header>

        <main style="flex:1; padding:2rem;">
            @if (TempData["Sucesso"] != null)
            {
                <div style="border:1px solid rgba(74,222,128,0.3); background:rgba(74,222,128,0.05); color:rgb(74,222,128); padding:0.75rem 1rem; margin-bottom:1.5rem; font-size:0.875rem;">
                    @TempData["Sucesso"]
                </div>
            }
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
