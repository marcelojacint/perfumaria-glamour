@{
    ViewBag.Title = "Configurações";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var hero = ViewBag.Hero as Glamour.Application.DTOs.HeroDto;
}

@if (TempData["Sucesso"] != null) {
    <div style="border:1px solid rgba(74,222,128,0.3); background:rgba(74,222,128,0.05); color:rgb(74,222,128); padding:0.75rem 1rem; margin-bottom:1.5rem; font-size:0.875rem;">@TempData["Sucesso"]</div>
}
@if (TempData["Erro"] != null) {
    <div style="border:1px solid rgba(248,113,113,0.4); background:rgba(127,29,29,0.15); color:rgb(248,113,113); padding:0.75rem 1rem; margin-bottom:1.5rem; font-size:0.875rem;">@TempData["Erro"]</div>
}

<div style="max-width:600px;">
    <form method="post" action="/admin/configuracoes" style="display:flex; flex-direction:column; gap:1.25rem;">
        @Html.AntiForgeryToken()

        <div style="border:1px solid rgba(212,175,55,0.2); background:rgba(24,24,27,0.5); padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
            <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.25rem;">Informações da Loja</h2>

            @{
                void C(string label, string name, string? valor, string type = "text")
                {
                    <div>
                        <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">@label</label>
                        <input type="@type" name="@name" value="@valor"
                               style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                    </div>;
                }
            }
            @{ C("Nome da Loja", "nome", ViewBag.Nome); }
            @{ C("Telefone / WhatsApp", "telefone", ViewBag.Telefone, "tel"); }
            @{ C("E-mail de Contato", "email", ViewBag.Email, "email"); }
            @{ C("Endereço Físico", "enderecoLoja", ViewBag.EnderecoLoja); }
            @{ C("Horário de Funcionamento", "horarioFuncionamento", ViewBag.HorarioFuncionamento); }
        </div>

        <div style="border:1px solid rgba(255,255,255,0.08); background:rgba(24,24,27,0.5); padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
            <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.25rem;">Frete</h2>
            @{ C("Valor mínimo para frete grátis (R$)", "limiteFreteGratis", ViewBag.LimiteFreteGratis, "number"); }
        </div>

        <button type="submit" class="btn-gold" style="padding:0.75rem 2rem; font-size:0.8rem; align-self:flex-start;">Salvar Configurações</button>
    </form>

    <form method="post" action="/admin/configuracoes/fonte"
          x-data="{ fonte: '@(hero?.FonteTitulo ?? "Playfair Display")' }"
          style="display:flex; flex-direction:column; gap:1.25rem; margin-top:2rem;">
        @Html.AntiForgeryToken()
        <div style="border:1px solid rgba(212,175,55,0.2); background:rgba(24,24,27,0.5); padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
            <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem;">
                <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em;">Tipografia (fonte dos títulos)</h2>
                <span style="font-size:0.62rem; color:rgba(74,222,128,0.8); text-transform:uppercase; letter-spacing:0.08em;">aplicado no site todo</span>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; align-items:start;">
                <div>
                    <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">Fonte</label>
                    <select name="fonte" x-model="fonte"
                            style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;">
                        @foreach (var f in Glamour.Web.Models.FontesSite.Disponiveis)
                        {
                            <option value="@f.Key">@f.Key — @f.Value</option>
                        }
                    </select>
                    <button type="submit" class="btn-gold" style="margin-top:1rem; padding:0.6rem 1.5rem; font-size:0.78rem;">Aplicar fonte</button>
                </div>
                <div>
                    <label style="font-size:0.65rem; color:rgba(255,255,255,0.4); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">Prévia</label>
                    <div style="border:1px solid rgba(255,255,255,0.08); background:#18181b; padding:1.25rem; text-align:center;"
                         x-bind:style="`font-family: '${fonte}', Georgia, serif`">
                        <div style="font-size:1.7rem; font-weight:700; color:#fff; line-height:1.1;">A Essência da <span style="color:#D4AF37;">Elegância</span></div>
                        <div style="font-size:0.95rem; color:rgba(255,255,255,0.6); margin-top:0.4rem;">Glamour Perfumaria</div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <form method="post" action="/admin/configuracoes/hero" enctype="multipart/form-data"
          style="display:flex; flex-direction:column; gap:1.25rem; margin-top:2rem;">
        @Html.AntiForgeryToken()
        <div style="border:1px solid rgba(212,175,55,0.2); background:rgba(24,24,27,0.5); padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
            <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem;">
                <h2 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em;">Banner principal (Home)</h2>
                <span style="font-size:0.62rem; color:rgba(74,222,128,0.8); text-transform:uppercase; letter-spacing:0.08em;">aplicado na hora</span>
            </div>

            <div>
                <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">Texto superior</label>
                <input type="text" name="eyebrow" value="@hero?.Eyebrow" placeholder="Ex.: Nova Coleção 2026 / Dia das Mães"
                       style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div>
                    <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">Título</label>
                    <input type="text" name="titulo" value="@hero?.Titulo" placeholder="Ex.: A Essência da"
                           style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                </div>
                <div>
                    <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">Palavra em destaque</label>
                    <input type="text" name="tituloDestaque" value="@hero?.TituloDestaque" placeholder="Ex.: Elegância"
                           style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box;" />
                </div>
            </div>

            <div>
                <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">Subtítulo</label>
                <textarea name="subtitulo" rows="2" placeholder="Frase de apoio da campanha..."
                          style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.875rem; box-sizing:border-box; resize:vertical;">@hero?.Subtitulo</textarea>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div>
                    <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">Cor de destaque</label>
                    <input type="color" name="corDestaque" value="@(hero?.CorDestaque ?? "#D4AF37")"
                           style="width:100%; height:2.6rem; background:#27272a; border:1px solid rgba(255,255,255,0.1); padding:0.2rem; box-sizing:border-box; cursor:pointer;" />
                </div>
                <div>
                    <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">Cor do texto</label>
                    <input type="color" name="corTexto" value="@(hero?.CorTexto ?? "#FFFFFF")"
                           style="width:100%; height:2.6rem; background:#27272a; border:1px solid rgba(255,255,255,0.1); padding:0.2rem; box-sizing:border-box; cursor:pointer;" />
                </div>
            </div>

            <div>
                <label style="font-size:0.65rem; color:rgba(212,175,55,0.6); text-transform:uppercase; letter-spacing:0.08em; display:block; margin-bottom:0.35rem;">Imagem de fundo (opcional)</label>
                @if (!string.IsNullOrEmpty(hero?.ImagemFundoUrl))
                {
                    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:0.6rem;">
                        <img src="@hero.ImagemFundoUrl" style="width:120px; height:64px; object-fit:cover; border:1px solid rgba(255,255,255,0.1);" />
                        <label style="font-size:0.75rem; color:rgba(255,255,255,0.6); display:flex; align-items:center; gap:0.4rem; cursor:pointer;">
                            <input type="checkbox" name="removerImagem" value="true" /> Remover imagem atual
                        </label>
                    </div>
                }
                <input type="file" name="imagem" accept="image/*"
                       style="width:100%; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.75rem; font-size:0.8rem; box-sizing:border-box;" />
                <p style="font-size:0.68rem; color:rgba(255,255,255,0.3); margin-top:0.35rem;">Recomendado: imagem larga (ex.: 1600×600). Sem imagem, mantém o fundo preto e dourado.</p>
            </div>

            <button type="submit" class="btn-gold" style="padding:0.75rem 2rem; font-size:0.8rem; align-self:flex-start;">Salvar Banner</button>
        </div>
    </form>

    <form method="post" action="/admin/configuracoes/hero/restaurar" style="margin-top:0.75rem;">
        @Html.AntiForgeryToken()
        <button type="submit"
                style="background:none; border:1px solid rgba(255,255,255,0.15); color:rgba(255,255,255,0.55); padding:0.5rem 1rem; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.08em; cursor:pointer;">
            Restaurar banner para o padrão
        </button>
    </form>
</div>
