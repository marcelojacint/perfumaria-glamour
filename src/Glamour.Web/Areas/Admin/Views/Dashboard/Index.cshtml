@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    decimal totalVendas = ViewBag.TotalVendasHoje ?? 0;
    int pedidosPendentes = ViewBag.PedidosPendentes ?? 0;
}

<div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:1.5rem; margin-bottom:2rem;">
    <div style="border:1px solid rgba(212,175,55,0.2); background:rgba(24,24,27,0.5); padding:1.5rem;">
        <div style="color:rgba(212,175,55,0.6); font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:0.5rem;">Vendas Hoje</div>
        <div class="font-playfair" style="font-size:1.75rem; font-weight:700; color:#D4AF37;">R$ @totalVendas.ToString("N2")</div>
    </div>
    <div style="border:1px solid rgba(212,175,55,0.2); background:rgba(24,24,27,0.5); padding:1.5rem;">
        <div style="color:rgba(212,175,55,0.6); font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:0.5rem;">Pedidos Pendentes</div>
        <div class="font-playfair" style="font-size:1.75rem; font-weight:700; color:#fff;">@pedidosPendentes</div>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
    <div style="border:1px solid rgba(255,255,255,0.08); background:rgba(24,24,27,0.5); padding:1.5rem;">
        <h3 style="font-size:0.875rem; font-weight:600; color:#D4AF37; margin:0 0 1rem; text-transform:uppercase; letter-spacing:0.1em;">Acesso Rápido</h3>
        <div style="display:flex; flex-direction:column; gap:0.75rem;">
            <a href="/admin/produtos/criar" style="color:rgba(255,255,255,0.7); text-decoration:none; font-size:0.875rem; display:flex; align-items:center; gap:0.5rem;">
                <span style="color:#D4AF37;">+</span> Novo Produto
            </a>
            <a href="/admin/categorias/criar" style="color:rgba(255,255,255,0.7); text-decoration:none; font-size:0.875rem; display:flex; align-items:center; gap:0.5rem;">
                <span style="color:#D4AF37;">+</span> Nova Categoria
            </a>
            <a href="/admin/pedidos" style="color:rgba(255,255,255,0.7); text-decoration:none; font-size:0.875rem; display:flex; align-items:center; gap:0.5rem;">
                <span style="color:#D4AF37;">→</span> Ver Pedidos
            </a>
        </div>
    </div>

    <div style="border:1px solid rgba(255,255,255,0.08); background:rgba(24,24,27,0.5); padding:1.5rem;">
        <h3 style="font-size:0.875rem; font-weight:600; color:#D4AF37; margin:0 0 1rem; text-transform:uppercase; letter-spacing:0.1em;">Status da Loja</h3>
        <div style="display:flex; flex-direction:column; gap:0.5rem; font-size:0.8rem; color:rgba(255,255,255,0.5);">
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <span style="width:8px; height:8px; border-radius:50%; background:rgb(74,222,128); display:inline-block;"></span>
                Loja online
            </div>
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <span style="width:8px; height:8px; border-radius:50%; background:rgb(74,222,128); display:inline-block;"></span>
                Banco de dados conectado
            </div>
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <span style="width:8px; height:8px; border-radius:50%; background:rgb(74,222,128); display:inline-block;"></span>
                Cache Redis ativo
            </div>
        </div>
    </div>
</div>
