@model Glamour.Application.DTOs.PedidoDto
@{
    ViewBag.Title = $"Pedido #{Model.Id.ToString()[..8].ToUpper()}";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div style="display:grid; grid-template-columns:2fr 1fr; gap:2rem; max-width:900px;">
    <div>
        <div style="border:1px solid rgba(255,255,255,0.08); padding:1.5rem; margin-bottom:1.5rem;">
            <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Itens do Pedido</h3>
            <table style="width:100%; font-size:0.875rem; border-collapse:collapse;">
                @foreach (var item in Model.Itens)
                {
                    <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
                        <td style="padding:0.5rem 0;">@item.NomeProduto</td>
                        <td style="padding:0.5rem 0; text-align:center; color:rgba(255,255,255,0.5);">×@item.Quantidade</td>
                        <td style="padding:0.5rem 0; text-align:right; color:#D4AF37;">R$ @item.Subtotal.ToString("N2")</td>
                    </tr>
                }
                <tr>
                    <td colspan="2" style="padding:0.75rem 0 0; font-weight:700; text-align:right; padding-right:1rem;">Total</td>
                    <td style="padding:0.75rem 0 0; text-align:right; font-weight:700; color:#D4AF37; font-size:1rem;">R$ @Model.Total.ToString("N2")</td>
                </tr>
            </table>
        </div>

        @if (Model.Endereco != null)
        {
            <div style="border:1px solid rgba(255,255,255,0.08); padding:1.5rem;">
                <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Endereço de Entrega</h3>
                <div style="font-size:0.875rem; color:rgba(255,255,255,0.6); line-height:1.7;">
                    <div>@Model.Endereco.Logradouro, @Model.Endereco.Numero @Model.Endereco.Complemento</div>
                    <div>@Model.Endereco.Bairro - @Model.Endereco.Cidade/@Model.Endereco.UF</div>
                    <div>CEP: @Model.Endereco.CEP</div>
                </div>
            </div>
        }
    </div>

    <div>
        <div style="border:1px solid rgba(212,175,55,0.2); padding:1.5rem; margin-bottom:1.5rem;">
            <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Informações</h3>
            <div style="font-size:0.8rem; color:rgba(255,255,255,0.5); display:flex; flex-direction:column; gap:0.5rem;">
                <div><span style="color:rgba(255,255,255,0.3);">Data:</span> @Model.CriadoEm.ToString("dd/MM/yyyy HH:mm")</div>
                <div><span style="color:rgba(255,255,255,0.3);">Entrega:</span> @(Model.TipoEntrega == Glamour.Domain.Enums.TipoEntrega.RetiradaNaLoja ? "Retirada na Loja" : "Entrega")</div>
                <div><span style="color:rgba(255,255,255,0.3);">Pagamento:</span> @Model.MetodoPagamento</div>
                @if (!string.IsNullOrEmpty(Model.Observacoes))
                {
                    <div><span style="color:rgba(255,255,255,0.3);">Obs:</span> @Model.Observacoes</div>
                }
            </div>
        </div>

        <div style="border:1px solid rgba(255,255,255,0.08); padding:1.5rem;">
            <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Atualizar Status</h3>
            <form method="post" action="/admin/pedidos/status" style="display:flex; flex-direction:column; gap:0.75rem;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PedidoId" value="@Model.Id" />
                <select name="NovoStatus" style="background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem 0.75rem; font-size:0.8rem;">
                    @foreach (var s in Enum.GetValues<Glamour.Domain.Enums.StatusPedido>())
                    {
                        <option value="@s" selected="@(Model.Status == s)">@s</option>
                    }
                </select>
                <button type="submit" class="btn-gold" style="padding:0.6rem; font-size:0.75rem;">Atualizar</button>
            </form>
        </div>
    </div>
</div>
