@model Glamour.Application.DTOs.PedidoDto
@{
    ViewBag.Title = $"Pedido #{Model.Id.ToString()[..8].ToUpper()}";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@if (TempData["Erro"] != null)
{
    <div style="border:1px solid rgba(248,113,113,0.4); background:rgba(127,29,29,0.15); color:rgb(248,113,113); padding:0.75rem 1rem; margin-bottom:1.5rem; font-size:0.875rem;">@TempData["Erro"]</div>
}

<div style="display:grid; grid-template-columns:2fr 1fr; gap:2rem; max-width:900px;">
    <div>
        <div style="border:1px solid rgba(255,255,255,0.08); padding:1.5rem; margin-bottom:1.5rem;">
            <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Itens do Pedido</h3>
            <table style="width:100%; font-size:0.875rem; border-collapse:collapse;">
                @foreach (var item in Model.Itens)
                {
                    <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
                        <td style="padding:0.5rem 0;">@item.NomeProduto</td>
                        <td style="padding:0.5rem 0; text-align:center; color:rgba(255,255,255,0.5);">×@item.Quantidade</td>
                        <td style="padding:0.5rem 0; text-align:right; color:#D4AF37;">R$ @item.Subtotal.ToString("N2")</td>
                    </tr>
                }
                <tr>
                    <td colspan="2" style="padding:0.75rem 0 0; font-weight:700; text-align:right; padding-right:1rem;">Total</td>
                    <td style="padding:0.75rem 0 0; text-align:right; font-weight:700; color:#D4AF37; font-size:1rem;">R$ @Model.Total.ToString("N2")</td>
                </tr>
            </table>
        </div>

        @if (Model.Endereco != null)
        {
            <div style="border:1px solid rgba(255,255,255,0.08); padding:1.5rem;">
                <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Endereço de Entrega</h3>
                <div style="font-size:0.875rem; color:rgba(255,255,255,0.6); line-height:1.7;">
                    <div>@Model.Endereco.Logradouro, @Model.Endereco.Numero @Model.Endereco.Complemento</div>
                    <div>@Model.Endereco.Bairro - @Model.Endereco.Cidade/@Model.Endereco.UF</div>
                    <div>CEP: @Model.Endereco.CEP</div>
                </div>
            </div>
        }
    </div>

    <div>
        @{
            string nomeCliente = ViewBag.NomeCliente ?? "Cliente";
            string emailCliente = ViewBag.EmailCliente ?? "";
            string telefoneCliente = ViewBag.TelefoneCliente ?? "";
            var telDigitos = new string((telefoneCliente ?? "").Where(char.IsDigit).ToArray());
            var waNumero = telDigitos.Length >= 10 ? (telDigitos.StartsWith("55") ? telDigitos : "55" + telDigitos) : "";
        }
        <div style="border:1px solid rgba(212,175,55,0.3); background:rgba(212,175,55,0.04); padding:1.5rem; margin-bottom:1.5rem;">
            <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Cliente</h3>
            <div style="font-size:0.875rem; color:rgba(255,255,255,0.75); display:flex; flex-direction:column; gap:0.4rem;">
                <div style="font-weight:600; color:#fff;">@nomeCliente</div>
                @if (!string.IsNullOrEmpty(telefoneCliente))
                {
                    <div style="display:flex; align-items:center; gap:0.5rem;">
                        <span style="color:rgba(255,255,255,0.4);">📞</span> @telefoneCliente
                    </div>
                }
                @if (!string.IsNullOrEmpty(emailCliente))
                {
                    <div style="display:flex; align-items:center; gap:0.5rem; font-size:0.8rem; color:rgba(255,255,255,0.5);">
                        <span style="color:rgba(255,255,255,0.4);">✉️</span> @emailCliente
                    </div>
                }
            </div>
            @if (!string.IsNullOrEmpty(waNumero))
            {
                <a href="https://wa.me/@waNumero?text=Ol%C3%A1%20@(Uri.EscapeDataString(nomeCliente))!%20Sobre%20o%20seu%20pedido%20%23@(Model.Id.ToString()[..8].ToUpper())..."
                   target="_blank"
                   style="display:inline-flex; align-items:center; gap:0.4rem; margin-top:1rem; background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.3); color:rgb(74,222,128); padding:0.5rem 0.875rem; font-size:0.75rem; text-decoration:none; border-radius:2px;">
                    💬 Falar no WhatsApp
                </a>
            }
        </div>

        <div style="border:1px solid rgba(212,175,55,0.2); padding:1.5rem; margin-bottom:1.5rem;">
            <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Informações</h3>
            <div style="font-size:0.8rem; color:rgba(255,255,255,0.5); display:flex; flex-direction:column; gap:0.5rem;">
                <div><span style="color:rgba(255,255,255,0.3);">Data:</span> @Model.CriadoEm.ToString("dd/MM/yyyy HH:mm")</div>
                <div><span style="color:rgba(255,255,255,0.3);">Entrega:</span> @(Model.TipoEntrega == Glamour.Domain.Enums.TipoEntrega.RetiradaNaLoja ? "Retirada na Loja" : "Entrega")</div>
                @if (Model.MetodoPagamentoPromocao != null)
                {
                    <div>
                        <span style="color:rgba(255,255,255,0.3);">Pagamento (dividido):</span>
                        <div style="padding-left:0.75rem; margin-top:0.25rem; line-height:1.6;">
                            <span style="color:#D4AF37;">🏷️ Promoção</span> (R$ @Model.ValorEmPromocao.ToString("N2")): <strong>@Model.MetodoPagamentoPromocao</strong><br/>
                            Demais (R$ @((Model.Total - Model.ValorEmPromocao).ToString("N2"))): <strong>@Model.MetodoPagamento</strong>
                        </div>
                    </div>
                }
                else
                {
                    <div><span style="color:rgba(255,255,255,0.3);">Pagamento:</span> @Model.MetodoPagamento</div>
                }
                @if (!string.IsNullOrEmpty(Model.Observacoes))
                {
                    <div><span style="color:rgba(255,255,255,0.3);">Obs:</span> @Model.Observacoes</div>
                }
            </div>
        </div>

        <div style="border:1px solid rgba(255,255,255,0.08); padding:1.5rem;">
            <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Atualizar Status</h3>
            <form method="post" action="/admin/pedidos/status" style="display:flex; flex-direction:column; gap:0.75rem;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PedidoId" value="@Model.Id" />
                <select name="NovoStatus" style="background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem 0.75rem; font-size:0.8rem;">
                    @foreach (var s in Enum.GetValues<Glamour.Domain.Enums.StatusPedido>())
                    {
                        <option value="@s" selected="@(Model.Status == s)">@s</option>
                    }
                </select>
                <button type="submit" class="btn-gold" style="padding:0.6rem; font-size:0.75rem;">Atualizar</button>
            </form>

            @if (Model.Status == Glamour.Domain.Enums.StatusPedido.Cancelado)
            {
                <div style="border-top:1px solid rgba(255,255,255,0.08); margin-top:1.25rem; padding-top:1.25rem;">
                    <form method="post" action="/admin/pedidos/@Model.Id/excluir"
                          onsubmit="return confirm('Excluir definitivamente este pedido cancelado? Esta ação não pode ser desfeita.');">
                        @Html.AntiForgeryToken()
                        <button type="submit" style="width:100%; background:none; border:1px solid rgba(248,113,113,0.4); color:rgba(248,113,113,0.9); padding:0.6rem; font-size:0.75rem; cursor:pointer; text-transform:uppercase; letter-spacing:0.05em;">
                            Excluir pedido
                        </button>
                    </form>
                </div>
            }

            <div style="border-top:1px solid rgba(255,255,255,0.08); margin-top:1.25rem; padding-top:1.25rem;">
                <h3 style="font-size:0.8rem; color:#D4AF37; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.875rem;">Rastreio</h3>
                @if (!string.IsNullOrEmpty(Model.CodigoRastreio))
                {
                    <div style="font-size:0.8rem; color:rgba(255,255,255,0.6); margin-bottom:0.75rem;">
                        Código atual: <strong style="color:#fff; font-family:monospace;">@Model.CodigoRastreio</strong>
                    </div>
                    <a href="https://rastreamento.correios.com.br/app/index.php" target="_blank"
                       style="font-size:0.75rem; color:#D4AF37; display:block; margin-bottom:0.75rem;">
                        Rastrear nos Correios →
                    </a>
                }
                <form method="post" action="/admin/pedidos/@Model.Id/rastreio" style="display:flex; flex-direction:column; gap:0.5rem;">
                    @Html.AntiForgeryToken()
                    <input type="text" name="codigoRastreio" placeholder="AA123456789BR" value="@Model.CodigoRastreio"
                           style="background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 0.6rem; font-size:0.8rem; font-family:monospace; text-transform:uppercase;" />
                    <button type="submit" style="background:none; border:1px solid rgba(212,175,55,0.4); color:#D4AF37; padding:0.4rem 0.75rem; font-size:0.72rem; cursor:pointer; letter-spacing:0.08em;">
                        Salvar e Marcar como Enviado
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
