@{
    ViewBag.Title = "Clientes";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var clientes = ViewBag.Clientes as IEnumerable<Glamour.Infrastructure.Identity.ApplicationUser> ?? [];
    int total = ViewBag.Total ?? 0;
    int paginaAtual = ViewBag.PaginaAtual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
}

<div style="display:flex; justify-content:space-between; margin-bottom:1.5rem;">
    <p style="color:rgba(255,255,255,0.4); font-size:0.8rem; margin:0;">@total cliente(s) cadastrado(s)</p>
</div>

<form method="get" style="margin-bottom:1.5rem; display:flex; gap:1rem;">
    <input type="text" name="busca" value="@Context.Request.Query["busca"]" placeholder="Nome ou e-mail..."
           style="flex:1; background:#27272a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.5rem 1rem; font-size:0.875rem;" />
    <button type="submit" class="btn-gold" style="padding:0.5rem 1.25rem; font-size:0.75rem;">Buscar</button>
</form>

<div style="border:1px solid rgba(255,255,255,0.08); overflow-x:auto;">
    <table style="width:100%; border-collapse:collapse; font-size:0.875rem;">
        <thead>
            <tr style="background:rgba(212,175,55,0.05); border-bottom:1px solid rgba(255,255,255,0.08);">
                @foreach (var col in new[] { "Nome", "E-mail", "Cadastro", "Pontos", "Status", "Ações" })
                {
                    <th style="text-align:left; padding:0.75rem 1rem; color:rgba(212,175,55,0.7); font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase; font-weight:600;">@col</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var c in clientes)
            {
                <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
                    <td style="padding:0.75rem 1rem; font-weight:500;">@c.Nome</td>
                    <td style="padding:0.75rem 1rem; color:rgba(255,255,255,0.5); font-size:0.8rem;">@c.Email</td>
                    <td style="padding:0.75rem 1rem; color:rgba(255,255,255,0.4); font-size:0.75rem;">@c.CriadoEm.ToString("dd/MM/yyyy")</td>
                    <td style="padding:0.75rem 1rem; color:#D4AF37; font-weight:600;">@c.PontosLoyalty</td>
                    <td style="padding:0.75rem 1rem;">
                        <span style="font-size:0.7rem; padding:0.15rem 0.5rem; border:1px solid; @(c.Ativo ? "border-color:rgba(74,222,128,0.4); color:rgb(74,222,128);" : "border-color:rgba(248,113,113,0.4); color:rgb(248,113,113);")">
                            @(c.Ativo ? "Ativo" : "Bloqueado")
                        </span>
                    </td>
                    <td style="padding:0.75rem 1rem;">
                        <div style="display:flex; gap:0.875rem;">
                            <a href="/admin/clientes/@c.Id" style="color:#D4AF37; font-size:0.75rem;">Ver</a>
                            <form method="post" action="/admin/clientes/toggle-ativo/@c.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background:none; border:none; cursor:pointer; color:rgba(255,255,255,0.4); font-size:0.75rem;">
                                    @(c.Ativo ? "Bloquear" : "Desbloquear")
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
